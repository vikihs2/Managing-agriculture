@model IEnumerable<ManagingAgriculture.Models.LeaveRequest>
@{
    ViewData["Title"] = "Manage Leave Requests";
}

<div class="dashboard-container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2><i class="fas fa-calendar-check me-2 text-success"></i>Leave Requests</h2>
            <p class="subtitle mb-0">Review and approve/reject employee leave requests</p>
        </div>
        <a asp-action="ManageStaff" class="btn btn-secondary">
            <i class="fas fa-arrow-left me-1"></i>Back to Staff
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="fas fa-exclamation-triangle me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Pending Requests -->
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-header text-white" style="background: linear-gradient(135deg, #d35400, #e67e22);">
            <h5 class="mb-0">
                <i class="fas fa-clock me-2"></i>Pending Requests
                <span class="badge bg-light text-dark ms-2">@Model.Count(r => r.Status == "Pending")</span>
            </h5>
        </div>
        <div class="card-body p-0">
            @{
                var pending = Model.Where(r => r.Status == "Pending").OrderBy(r => r.LeaveDate).ToList();
            }
            @if (pending.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0 align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Employee</th>
                                <th>Date Requested Off</th>
                                <th>Reason</th>
                                <th>Submitted</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var req in pending)
                            {
                                <tr>
                                    <td class="fw-bold">@req.User?.Email</td>
                                    <td>
                                        <span class="badge bg-warning text-dark fs-6">
                                            @req.LeaveDate.ToString("dddd, dd MMM yyyy")
                                        </span>
                                    </td>
                                    <td class="text-muted">@(req.Reason ?? "—")</td>
                                    <td class="text-muted small">@req.RequestedDate.ToString("dd MMM yyyy HH:mm")</td>
                                    <td>
                                        <div class="d-flex gap-2">
                                            <form asp-action="ApproveLeaveRequest" method="post" style="display:inline;">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="requestId" value="@req.Id" />
                                                <button type="submit" class="btn btn-sm btn-success"
                                                        onclick="return confirm('Approve leave for @req.User?.Email on @req.LeaveDate.ToString("d")?');">
                                                    <i class="fas fa-check me-1"></i>Approve
                                                </button>
                                            </form>
                                            <button class="btn btn-sm btn-danger" data-bs-toggle="modal"
                                                    data-bs-target="#rejectModal"
                                                    onclick="setRejectId(@req.Id, '@req.User?.Email', '@req.LeaveDate.ToString("d")')">
                                                <i class="fas fa-times me-1"></i>Reject
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-4 text-muted">
                    <i class="fas fa-check-circle fa-2x mb-2 text-success opacity-50"></i>
                    <p>No pending leave requests! All caught up.</p>
                </div>
            }
        </div>
    </div>

    <!-- All Requests History -->
    <div class="card shadow-sm border-0">
        <div class="card-header bg-light">
            <h5 class="mb-0"><i class="fas fa-history me-2"></i>All Requests History</h5>
        </div>
        <div class="card-body p-0">
            @if (Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-sm mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Employee</th>
                                <th>Date</th>
                                <th>Reason</th>
                                <th>Status</th>
                                <th>Boss Note</th>
                                <th>Decided</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var req in Model.OrderByDescending(r => r.LeaveDate))
                            {
                                <tr>
                                    <td>@req.User?.Email</td>
                                    <td class="fw-bold">@req.LeaveDate.ToString("dd MMM yyyy")</td>
                                    <td class="text-muted small">@(req.Reason ?? "—")</td>
                                    <td>
                                        @if (req.Status == "Approved")
                                        {
                                            <span class="badge bg-success">✅ Approved</span>
                                        }
                                        else if (req.Status == "Rejected")
                                        {
                                            <span class="badge bg-danger">❌ Rejected</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning text-dark">⏳ Pending</span>
                                        }
                                    </td>
                                    <td class="text-muted small">@(req.BossNote ?? "—")</td>
                                    <td class="text-muted small">@(req.DecidedDate?.ToString("dd MMM yyyy") ?? "—")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-center text-muted py-3">No leave requests yet.</p>
            }
        </div>
    </div>
</div>

<!-- Reject Modal -->
<div class="modal fade" id="rejectModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <form asp-action="RejectLeaveRequest" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="requestId" id="rejectRequestId" />
            <div class="modal-content">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title"><i class="fas fa-times me-2"></i>Reject Leave Request</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p>Reject leave for <strong id="rejectUserName"></strong> on <strong id="rejectDate"></strong>?</p>
                    <div class="mb-3">
                        <label class="form-label">Note / Reason (Optional)</label>
                        <input type="text" name="note" class="form-control" placeholder="e.g. Critical project deadline" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger">Reject Request</button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function setRejectId(id, userName, date) {
            document.getElementById('rejectRequestId').value = id;
            document.getElementById('rejectUserName').textContent = userName;
            document.getElementById('rejectDate').textContent = date;
        }
    </script>
}
