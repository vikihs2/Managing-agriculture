@model List<ManagingAgriculture.Models.Field>
@{
    ViewData["Title"] = "Manage Fields";
}

<div class="dashboard-container">
    <!-- Title is handled by _Layout.cshtml -->
    
    <div class="mb-3">
        <a asp-action="CreateField" class="btn btn-success">+ Add New Field</a>
    </div>

    @if (Model != null && Model.Count > 0)
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Field Name</th>
                        <th>Size (Decars)</th>
                        <th>City</th>
                        <th>Soil Type</th>
                        <th>Sunlight</th>
                        <th>Avg Temp (°C)</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var field in Model)
                    {
                        <tr>
                            <td>@field.Name</td>
                            <td>@field.SizeInDecars</td>
                            <td>@field.City</td>
                            <td>@field.SoilType</td>
                            <td>@field.SunlightExposure</td>
                            <td>@field.AverageTemperatureCelsius</td>
                            <td>
                                @if (field.IsOccupied)
                                {
                                    <span class="badge bg-warning">Occupied</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Available</span>
                                }
                            </td>
                            <td>
                                <a asp-action="EditField" asp-route-id="@field.Id" class="btn btn-sm btn-primary">Edit</a>
                                <form asp-action="DeleteField" asp-route-id="@field.Id" method="post" style="display:inline;">
                                    <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Are you sure?');">Delete</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            No fields created yet. <a asp-action="CreateField">Create the first field</a>.
        </div>
    }
</div>
