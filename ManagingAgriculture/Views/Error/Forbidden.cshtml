@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Access Denied";
}

<div class="container py-5">
    <div class="text-center">
        <div style="font-size: 120px; color: #c41e3a; font-weight: bold; margin-bottom: 20px;">⛔</div>
        
        <h1 style="font-size: 36px; color: #8B0000; margin-bottom: 20px;">This is a restricted page</h1>
        
        <p style="font-size: 18px; color: #666; margin-bottom: 30px;">
            Only admins can enter!
        </p>
        
        <div style="margin-bottom: 40px; position: relative;">
            <svg width="300" height="280" viewBox="0 0 300 280" style="max-width: 100%; height: auto;">
                <!-- Security guard illustration -->
                <!-- Head -->
                <circle cx="150" cy="60" r="25" fill="#FDBCB4"/>
                <!-- Body -->
                <rect x="130" y="90" width="40" height="50" fill="white" stroke="navy" stroke-width="2"/>
                <rect x="130" y="90" width="40" height="15" fill="#1a1a7f"/>
                <!-- Cap -->
                <ellipse cx="150" cy="50" rx="30" ry="12" fill="#FFD700"/>
                <text x="150" y="58" font-size="8" fill="black" text-anchor="middle" font-weight="bold">SECURITY</text>
                <!-- Arms -->
                <rect x="100" y="100" width="30" height="12" fill="#FDBCB4"/>
                <rect x="170" y="100" width="30" height="12" fill="#FDBCB4"/>
                <!-- Legs -->
                <rect x="135" y="145" width="10" height="40" fill="black"/>
                <rect x="155" y="145" width="10" height="40" fill="black"/>
                <!-- Stop sign -->
                <polygon points="240,100 260,100 270,120 260,140 240,140 230,120" fill="#c41e3a" stroke="white" stroke-width="2"/>
                <text x="250" y="130" font-size="20" fill="white" text-anchor="middle" font-weight="bold">STOP</text>
                <!-- Barrier -->
                <rect x="100" y="195" width="100" height="8" fill="#FFD700"/>
                <rect x="105" y="200" width="5" height="15" fill="black"/>
                <rect x="130" y="200" width="5" height="15" fill="black"/>
                <rect x="155" y="200" width="5" height="15" fill="black"/>
                <rect x="180" y="200" width="5" height="15" fill="black"/>
                <!-- Warning stripes -->
                <line x1="110" y1="215" x2="130" y2="215" stroke="#FFD700" stroke-width="3"/>
                <line x1="140" y1="215" x2="160" y2="215" stroke="#FFD700" stroke-width="3"/>
                <line x1="170" y1="215" x2="190" y2="215" stroke="#FFD700" stroke-width="3"/>
            </svg>
        </div>
        
        <div>
            <a href="@Url.Action("Index", "Home")" class="btn btn-primary btn-lg" style="margin-right: 10px;">
                Go to Homepage
            </a>
            <a href="@Url.Action("Index", "Dashboard")" class="btn btn-secondary btn-lg">
                Go to Dashboard
            </a>
        </div>
    </div>
</div>

<style>
    body {
        background: linear-gradient(135deg, #ffe0e0 0%, #fff0f0 100%);
    }
</style>
