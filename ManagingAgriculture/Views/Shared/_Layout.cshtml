@using Microsoft.EntityFrameworkCore
@inject Microsoft.AspNetCore.Identity.UserManager<ManagingAgriculture.Models.ApplicationUser> UserManager
@inject ManagingAgriculture.Data.ApplicationDbContext DbContext

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Agriculture Management System</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
</head>
<body>
    @{
        var controller = ViewContext.RouteData.Values["controller"]?.ToString();
        var action = ViewContext.RouteData.Values["action"]?.ToString();
        var showSidebar = !(controller == "Home" && action == "Contact");

        string companyName = "";
        string welcomeName = "User";
        string userEmail = "";
        int unreadCount = 0;

        if (User?.Identity?.IsAuthenticated == true)
        {
            var user = await UserManager.GetUserAsync(User);
            if (user != null)
            {
                userEmail = user.Email ?? "";
                if (user.CompanyId != null)
                {
                    var company = await DbContext.Companies.FindAsync(user.CompanyId);
                    companyName = company?.Name ?? "";
                }

                // Determine display name
                if (!string.IsNullOrEmpty(userEmail) && userEmail.Contains("@"))
                {
                    var raw = userEmail.Split('@')[0];
                    welcomeName = raw.Length > 0 ? char.ToUpper(raw[0]) + raw.Substring(1) : raw;
                }

                // Special role names
                if (User.IsInRole("SystemAdmin") || welcomeName.Equals("admin", StringComparison.OrdinalIgnoreCase))
                    welcomeName = "Admin";
                else if (User.IsInRole("ITSupport"))
                    welcomeName = "IT Support";
                else if (User.IsInRole("Boss"))
                    welcomeName = "Boss";

                // Calculate unread inbox count
                if (User.IsInRole("SystemAdmin") || User.IsInRole("ITSupport"))
                {
                    // Admin/IT: count unreplied messages
                    unreadCount = await DbContext.ContactForms
                        .CountAsync(m => !m.IsReplied);
                }
                else
                {
                    // Regular user: count replies they haven't read
                    unreadCount = await DbContext.ContactForms
                        .CountAsync(m => m.Email == userEmail && m.IsReplied && !m.IsReadByUser);
                }
            }
        }

        // Determine if Add button should show
        bool isEmployee = User.IsInRole("Employee");
        bool isManager = User.IsInRole("Manager");
        bool isBoss    = User.IsInRole("Boss");
        bool isAdminRole = User.IsInRole("SystemAdmin");
        bool isITRole    = User.IsInRole("ITSupport");
        bool isCompanyRole = isEmployee || isManager || isBoss;
        bool isNonCompanyUser = !isCompanyRole; // User/Admin/IT are not company-role users
        bool canAddToPage = false;
        if (new[] { "Plants", "Resources", "Machinery", "Marketplace" }.Contains(controller))
        {
            if (controller == "Plants" && (!isEmployee || isNonCompanyUser)) canAddToPage = true;
            else if (controller == "Resources" && (!isEmployee || isNonCompanyUser)) canAddToPage = true;
            else if (controller == "Machinery" && (isBoss || isNonCompanyUser)) canAddToPage = true;
            else if (controller == "Marketplace" && (isBoss || isNonCompanyUser)) canAddToPage = true;
        }
    }

    <div class="d-flex">
        @if (showSidebar)
        {
            <nav class="sidebar">
                <div class="sidebar-brand">
                    <div class="brand-emoji" aria-hidden="true">🌱</div>
                    <span class="brand-text">AgroCore</span>
                </div>
                <div class="sidebar-menu">
                    <p class="menu-title">Main Menu</p>
                    <a href="@Url.Action("Index", "Dashboard")" class="menu-item dashboard-link">
                        <i class="fas fa-home"></i>
                        <span>Dashboard</span>
                    </a>
                    <a href="@Url.Action("Index", "Plants")" class="menu-item">
                        <i class="fas fa-leaf"></i>
                        <span>Plant Tracking</span>
                    </a>

                    @* Fields - visible to all authenticated users (needed for plant tracking) *@
                    @if (User?.Identity?.IsAuthenticated == true)
                    {
                        <a href="@Url.Action("Index", "Fields")" class="menu-item">
                            <i class="fas fa-map-marked-alt"></i>
                            <span>Fields</span>
                        </a>
                    }

                    <a href="@Url.Action("Index", "Resources")" class="menu-item">
                        <i class="fas fa-box"></i>
                        <span>Resources</span>
                    </a>
                    <a href="@Url.Action("Index", "Machinery")" class="menu-item">
                        <i class="fas fa-cogs"></i>
                        <span>Machinery</span>
                    </a>
                    <a href="@Url.Action("Index", "Marketplace")" class="menu-item">
                        <i class="fas fa-shopping-cart"></i>
                        <span>Marketplace</span>
                    </a>
                    <a href="@Url.Action("Index", "Sensors")" class="menu-item">
                        <i class="fas fa-tint"></i>
                        <span>Soil Humidity</span>
                    </a>

                    @* Role-specific panel links *@
                    @if (User.IsInRole("Boss"))
                    {
                        <p class="menu-title">Management</p>
                        <a href="@Url.Action("Index", "Boss")" class="menu-item">
                            <i class="fas fa-crown"></i>
                            <span>Boss Panel</span>
                        </a>
                        <a href="@Url.Action("ManageStaff", "Boss")" class="menu-item">
                            <i class="fas fa-users-cog"></i>
                            <span>Manage Staff</span>
                        </a>
                    }

                    @if (User.IsInRole("Manager"))
                    {
                        <p class="menu-title">My Panel</p>
                        <a href="@Url.Action("Index", "Manager")" class="menu-item">
                            <i class="fas fa-briefcase"></i>
                            <span>Manager Panel</span>
                        </a>
                    }

                    @if (User.IsInRole("Employee"))
                    {
                        <p class="menu-title">My Panel</p>
                        <a href="@Url.Action("Index", "Employee")" class="menu-item">
                            <i class="fas fa-hard-hat"></i>
                            <span>Employee Panel</span>
                        </a>
                    }

                    @if (User.IsInRole("SystemAdmin"))
                    {
                        <a href="@Url.Action("Index", "Admin")" class="menu-item" style="color:red">
                            <i class="fas fa-user-shield"></i>
                            <span>Admin Panel</span>
                        </a>
                    }

                    @if (User.IsInRole("ITSupport"))
                    {
                        <p class="menu-title">IT</p>
                        <a href="@Url.Action("Index", "ITSupport")" class="menu-item">
                            <i class="fas fa-tools"></i>
                            <span>IT Panel</span>
                        </a>
                    }

                    <p class="menu-title">Account</p>
                    @if (User?.Identity?.IsAuthenticated == true)
                    {
                        <a href="@Url.Action("Index", "Inbox")" class="menu-item" style="position:relative;">
                            <i class="fas fa-envelope"></i>
                            <span>Inbox</span>
                            @if (unreadCount > 0)
                            {
                                <span class="inbox-badge">@(unreadCount > 9 ? "9+" : unreadCount.ToString())</span>
                            }
                        </a>
                        <form asp-controller="Account" asp-action="Logout" method="post" class="menu-item" style="display:flex;align-items:center;gap:8px;">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-cancel" style="display:flex;align-items:center;gap:8px;padding:6px 10px;border-radius:6px;">
                                <i class="fas fa-sign-out-alt"></i>
                                <span class="signout-text">Sign out</span>
                            </button>
                        </form>
                    }
                </div>
            </nav>
        }

        <main class="main-content@(showSidebar ? " main-content-expanded" : "")">
            <header class="top-header">
                <div class="header-row">
                    <h1>@ViewData["Title"]</h1>

                    <div class="ms-auto nav-right">
                        <button class="btn btn-outline-secondary me-3" id="themeToggle" title="Toggle Theme">
                            <i class="fas fa-moon"></i>
                        </button>

                        @if (new[] { "Plants", "Resources", "Machinery", "Marketplace" }.Contains(controller))
                        {
                            @* Show Add button only for roles that can add to this page *@
                            @if (canAddToPage)
                            {
                                <a class="btn btn-add me-2" href="@Url.Action("Add", controller)">
                                    <i class="fas fa-plus"></i> Add
                                </a>
                            }
                            <a href="@Url.Action("Index", "Home")" class="home-link ms-3" title="Home">
                                <div class="home-icon"><i class="fas fa-home"></i></div>
                            </a>
                        }
                        else
                        {
                            @if (User?.Identity?.IsAuthenticated == true)
                            {
                                <span class="me-3">Welcome @welcomeName!</span>
                                @if (controller == "Home")
                                {
                                    <a class="btn btn-dashboard me-2" href="@Url.Action("Index", "Dashboard")">Dashboard</a>
                                    <form asp-controller="Account" asp-action="Logout" method="post" style="display:inline-block;">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-cancel">Sign out</button>
                                    </form>
                                }
                                <a href="@Url.Action("Index", "Home")" class="home-link ms-3" title="Home">
                                    <div class="home-icon"><i class="fas fa-home"></i></div>
                                </a>
                            }
                            else
                            {
                                <a href="@Url.Action("Index", "Home")" class="home-link ms-3" title="Home">
                                    <div class="home-icon"><i class="fas fa-home"></i></div>
                                </a>
                            }
                        }
                    </div>
                </div>
            </header>
            <div class="content-wrapper">
                @RenderBody()
            </div>
        </main>
    </div>

    <!-- Bottom Navigation for Mobile -->
    <nav class="bottom-nav">
        <a href="@Url.Action("Index", "Dashboard")" class="nav-item @(controller == "Dashboard" ? "active" : "")">
            <i class="fas fa-home"></i>
            <span>Home</span>
        </a>
        <a href="@Url.Action("Index", "Plants")" class="nav-item @(controller == "Plants" ? "active" : "")">
            <i class="fas fa-leaf"></i>
            <span>Plants</span>
        </a>
        <a href="@Url.Action("Index", "Fields")" class="nav-item @(controller == "Fields" ? "active" : "")">
            <i class="fas fa-map-marked-alt"></i>
            <span>Fields</span>
        </a>
        <a href="@Url.Action("Index", "Resources")" class="nav-item @(controller == "Resources" ? "active" : "")">
            <i class="fas fa-box"></i>
            <span>Stock</span>
        </a>
        <a href="@Url.Action("Index", "Marketplace")" class="nav-item @(controller == "Marketplace" ? "active" : "")">
            <i class="fas fa-shopping-cart"></i>
            <span>Market</span>
        </a>
        @if (User?.Identity?.IsAuthenticated == true)
        {
            <form asp-controller="Account" asp-action="Logout" method="post" class="nav-item" style="background:none;border:none;padding:0;">
                @Html.AntiForgeryToken()
                <button type="submit" style="background:none;border:none;color:inherit;display:flex;flex-direction:column;align-items:center;padding:0;">
                    <i class="fas fa-sign-out-alt"></i>
                    <span>Exit</span>
                </button>
            </form>
        }
    </nav>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @RenderSection("Scripts", required: false)
    <script>
        // Theme Toggle Logic
        document.addEventListener('DOMContentLoaded', function() {
            const toggle = document.getElementById('themeToggle');
            const body = document.body;
            const icon = toggle.querySelector('i');

            const getCookie = (name) => {
                const value = `; ${document.cookie}`;
                const parts = value.split(`; ${name}=`);
                if (parts.length === 2) return parts.pop().split(';').shift();
            }

            if (getCookie('theme') === 'dark') {
                body.classList.add('dark-mode');
                icon.classList.replace('fa-moon', 'fa-sun');
            }

            toggle.addEventListener('click', function() {
                body.classList.toggle('dark-mode');
                if (body.classList.contains('dark-mode')) {
                    document.cookie = "theme=dark; path=/; max-age=31536000";
                    icon.classList.replace('fa-moon', 'fa-sun');
                } else {
                    document.cookie = "theme=light; path=/; max-age=31536000";
                    icon.classList.replace('fa-sun', 'fa-moon');
                }
            });
        });
    </script>
</body>
</html>
