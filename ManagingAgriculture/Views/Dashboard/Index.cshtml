@model ManagingAgriculture.ViewModels.DashboardViewModel
@using ManagingAgriculture.Models
@{
    ViewData["Title"] = "Dashboard";
}

<div class="dashboard-container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
             <p class="subtitle mb-0">Overview of your farm operations</p>
             @if (User.Identity.IsAuthenticated && ViewBag.CompanyName != null)
             {
                 <div class="d-flex align-items-center mt-2">
                    @if (ViewBag.CompanyLogo != null)
                    {
                         <img src="@ViewBag.CompanyLogo" alt="Logo" class="rounded-circle me-2 border" style="width: 50px; height: 50px; object-fit: cover;" />
                    }
                    <h2 class="text-success mb-0"><i class="fas fa-building" style="@(ViewBag.CompanyLogo != null ? "display:none;" : "")"></i> @ViewBag.CompanyName</h2>
                 </div>
             }
        </div>
        
        <div class="d-flex gap-2 align-items-center">
            <a asp-controller="Inbox" asp-action="Index" class="btn btn-warning text-dark position-relative">
                <i class="fas fa-envelope"></i> Check Inbox
                @if (ViewBag.UnreadMessageCount != null && (int)ViewBag.UnreadMessageCount > 0)
                {
                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                        @ViewBag.UnreadMessageCount
                    </span>
                }
            </a>

            @if (User.IsInRole("Boss"))
            {
                <a href="@Url.Action("Index", "Boss")" class="btn text-white" style="background-color: var(--brand-green);">Back to Boss Panel</a>
            }
            @if (User.IsInRole("Employee"))
            {
                <a href="@Url.Action("Index", "Employee")" class="btn btn-info text-white">Employee Panel</a>
            }
            @if (User.IsInRole("Manager"))
            {
                <a href="@Url.Action("Index", "Manager")" class="btn btn-warning text-dark">Manager Panel</a>
            }
            @if (User.IsInRole("SystemAdmin"))
            {
                <a href="@Url.Action("Index", "Admin")" class="btn btn-dark">Back to Admin Panel</a>
            }
            @if (User.IsInRole("ITSupport"))
            {
                <a href="@Url.Action("Index", "ITSupport")" class="btn btn-info text-white">Back to IT Panel</a>
            }
        </div>
    </div>

    <!-- Job Offers Section -->
    @if (ViewBag.PendingInvites != null && ((List<CompanyInvitation>)ViewBag.PendingInvites).Count > 0)
    {
        <div class="alert alert-info">
            <h4><i class="fas fa-briefcase"></i> Job Offers</h4>
            <p>You have been invited to join a company!</p>
            <div class="list-group">
                @foreach (var invite in (List<CompanyInvitation>)ViewBag.PendingInvites)
                {
                    <div class="list-group-item d-flex justify-content-between align-items-center">
                        <div>
                            <strong>@(invite.Company != null ? invite.Company.Name : "A Company")</strong>
                            <span class="badge bg-primary ms-2">@invite.Role</span>
                        </div>
                        <div class="d-flex gap-2">
                             <form asp-action="AcceptInvite" method="post">
                                 <input type="hidden" name="inviteId" value="@invite.Id" />
                                 <button type="submit" class="btn btn-success btn-sm">Accept</button>
                             </form>
                             <form asp-action="DeclineInvite" method="post">
                                 <input type="hidden" name="inviteId" value="@invite.Id" />
                                 <button type="submit" class="btn btn-danger btn-sm">Decline</button>
                             </form>
                        </div>
                    </div>
                }
            </div>
        </div>
    }


    <!-- Weather Widget -->
    <div class="card mb-4 shadow-sm">
        <div class="card-header bg-gradient bg-primary text-white d-flex justify-content-between align-items-center">
             <div class="d-flex align-items-center gap-3">
                 <h5 class="mb-0"><i class="fas fa-cloud-sun me-2"></i> Weather:</h5>
                 <select id="weatherCity" class="form-select form-select-sm" style="width: 150px; background-color: rgba(255,255,255,0.9); border:none; border-radius: 4px; font-weight:bold;">
                     <option value="42.6977,23.3219">Sofia</option>
                     <option value="42.1438,24.7497">Plovdiv</option>
                     <option value="43.2046,27.9105">Varna</option>
                     <option value="42.5061,27.4678">Burgas</option>
                     <option value="43.8564,25.9708">Ruse</option>
                     <option value="42.4328,25.6419">Stara Zagora</option>
                     <option value="43.4170,24.6067">Pleven</option>
                     <option value="42.6858,26.3292">Sliven</option>
                     <option value="43.5667,27.8333">Dobrich</option>
                     <option value="43.2706,26.9229">Shumen</option>
                 </select>
             </div>
             <div id="weather-temp" class="fs-4 fw-bold">--°C</div>
        </div>
        <div class="card-body bg-light">
             <div id="weather-details" class="d-flex justify-content-around align-items-center text-center">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
             </div>
        </div>
    </div>
    
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const citySelect = document.getElementById('weatherCity');
            
            function loadWeather() {
                const [lat, lng] = citySelect.value.split(',');
                document.getElementById('weather-details').innerHTML = '<div class="spinner-border text-primary" role="status"><span class="visually-hidden">Loading...</span></div>';
                
                fetch(`https://api.open-meteo.com/v1/forecast?latitude=${lat}&longitude=${lng}&current_weather=true`)
                .then(response => response.json())
                .then(data => {
                    if(data.current_weather) {
                        const w = data.current_weather;
                        document.getElementById('weather-temp').innerText = w.temperature + "°C";
                        
                        let icon = '<i class="fas fa-sun fa-3x text-warning"></i>';
                        if(w.weathercode > 3) icon = '<i class="fas fa-cloud fa-3x text-secondary"></i>';
                        if(w.weathercode > 50) icon = '<i class="fas fa-cloud-rain fa-3x text-primary"></i>';
                        if(w.weathercode > 70) icon = '<i class="fas fa-snowflake fa-3x text-info"></i>';

                        document.getElementById('weather-details').innerHTML = `
                            <div>
                                ${icon}
                                <p class="mb-0 mt-1 text-muted">Condition</p>
                            </div>
                            <div>
                                <i class="fas fa-wind fa-2x text-muted mb-2"></i>
                                <h5 class="mb-0">${w.windspeed} km/h</h5>
                                <small class="text-muted">Wind Speed</small>
                            </div>
                            <div>
                                <i class="fas fa-compass fa-2x text-muted mb-2"></i>
                                <h5 class="mb-0">${w.winddirection}°</h5>
                                <small class="text-muted">Wind Dir</small>
                            </div>
                        `;
                    }
                })
                .catch(err => {
                    document.getElementById('weather-details').innerHTML = '<p class="text-danger">Failed to load weather data.</p>';
                });
            }

            const savedCity = localStorage.getItem('weatherCitySetting');
            if (savedCity) {
                citySelect.value = savedCity;
            }

            citySelect.addEventListener('change', function() {
                localStorage.setItem('weatherCitySetting', this.value);
                loadWeather();
            });

            loadWeather();
        });
    </script>

    <!-- Statistics Cards -->
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-header">
                <h3>Active Plants</h3>
                <i class="fas fa-leaf stat-icon"></i>
            </div>
            <div class="stat-number">@Model.ActivePlantsCount</div>
            <div class="stat-label">Crops being tracked</div>
        </div>

        <div class="stat-card">
            <div class="stat-header">
                <h3>Resources</h3>
                <i class="fas fa-box stat-icon"></i>
            </div>
            <div class="stat-number">@Model.ResourcesCount</div>
            <div class="stat-label">Items in inventory</div>
        </div>

        <div class="stat-card">
            <div class="stat-header">
                <h3>Machinery</h3>
                <i class="fas fa-cogs stat-icon"></i>
            </div>
            <div class="stat-number">@Model.MachineryCount</div>
            <div class="stat-label">Equipment units</div>
        </div>

        <div class="stat-card @(Model.LowStockCount > 0 ? "alert-card" : "")">
            <div class="stat-header">
                <h3>Low Stock Alerts</h3>
                <i class="fas fa-exclamation-triangle stat-icon"></i>
            </div>
            <div class="stat-number">@Model.LowStockCount</div>
            <div class="stat-label">Items need restock</div>
        </div>
    </div>

    <!-- Active Crops Section -->
    <div class="crops-section">
        <div class="section-header">
            <i class="fas fa-leaf"></i>
            <h3>Active Crops</h3>
        </div>
        <p class="section-subtitle">Monitor your growing plants and upcoming tasks</p>

        <div class="crops-list">
            @if (Model.ActiveCrops != null && Model.ActiveCrops.Any())
            {
                foreach (var plant in Model.ActiveCrops)
                {
                    <div class="crop-item">
                        <div class="crop-name">
                            <h4>@plant.Name</h4>
                            <span class="crop-type">@plant.PlantType</span>
                        </div>
                        <div class="crop-progress">
                            <div class="progress-bar-container">
                                <div class="progress-bar" style="width: @(plant.GrowthStagePercent)%;"></div>
                            </div>
                        </div>
                        <div class="crop-info">
                            <span class="next-task">Next: @(string.IsNullOrEmpty(plant.NextTask) ? "No task scheduled" : plant.NextTask)</span>
                            <span class="growth-rate">@plant.GrowthStagePercent% Growth</span>
                        </div>
                    </div>
                }
            }
            else
            {
                <p class="text-muted">No active crops found. <a href="@Url.Action("Add", "Plants")">Add a new plant</a> to get started.</p>
            }
        </div>
    </div>

    <!-- Harvest Statistics Section -->
    <div class="card mt-4 shadow-sm border-0">
        <div class="card-header text-white d-flex align-items-center gap-2" style="background: linear-gradient(135deg, #e76f51, #c1440e);">
            <i class="fas fa-wheat-alt fa-lg"></i>
            <h5 class="mb-0">🌾 Harvest Statistics</h5>
            <span class="badge bg-light text-dark ms-auto">@Model.RecentHarvests.Count total</span>
        </div>
        <div class="card-body p-0">
            @if (Model.RecentHarvests != null && Model.RecentHarvests.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0 align-middle">
                        <thead class="table-light">
                            <tr>
                                <th><i class="fas fa-seedling me-1"></i>Plant</th>
                                <th><i class="fas fa-tag me-1"></i>Type</th>
                                <th><i class="fas fa-map-pin me-1"></i>Field</th>
                                <th><i class="fas fa-ruler-combined me-1"></i>Size</th>
                                <th><i class="fas fa-weight me-1"></i>Yield</th>
                                <th><i class="fas fa-calendar me-1"></i>Harvested</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var harvest in Model.RecentHarvests)
                            {
                                <tr>
                                    <td class="fw-bold">@harvest.PlantName</td>
                                    <td><span class="badge bg-success">@harvest.PlantType</span></td>
                                    <td>@(harvest.FieldName ?? "—")</td>
                                    <td>@(harvest.FieldSizeDecars.HasValue ? $"{harvest.FieldSizeDecars:N1} dec." : "—")</td>
                                    <td class="fw-bold text-warning">
                                        <i class="fas fa-wheat-alt me-1"></i>@harvest.EstimatedYieldKg.ToString("N0") kg
                                    </td>
                                    <td class="text-muted small">@harvest.HarvestedDate.ToString("dd MMM yyyy")</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-light fw-bold">
                            <tr>
                                <td colspan="4">Total Harvested</td>
                                <td class="text-warning">@Model.RecentHarvests.Sum(h => h.EstimatedYieldKg).ToString("N0") kg</td>
                                <td></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-4 text-muted">
                    <i class="fas fa-seedling fa-2x mb-2 opacity-25"></i>
                    <p>No harvests yet. Grow your plants to 100% and harvest them!</p>
                </div>
            }
        </div>
    </div>
</div>
