@model IEnumerable<ManagingAgriculture.Models.Plant>
@{
    ViewData["Title"] = "Plant Tracking";
    bool isEmployee = User.IsInRole("Employee");
    bool isBoss = User.IsInRole("Boss");
    bool isManager = User.IsInRole("Manager");
    bool isAdmin = User.IsInRole("SystemAdmin");
    bool isIT = User.IsInRole("ITSupport");
    bool isCompanyUser = isBoss || isManager || isEmployee;
    // Non-company users (normal User, Admin, IT) can delete their own plants
    bool canDelete = isBoss || (!isCompanyUser);
}

<div class="plants-container">
    <div class="page-header d-flex justify-content-between align-items-center">
        <div>
            <p class="subtitle">Monitor your crops and growth stages</p>
        </div>
        <div class="d-flex gap-2">
            @if (!isEmployee)
            {
                <a href="@Url.Action("Add", "Plants")" class="btn btn-success">
                    <i class="fas fa-plus me-1"></i>Add Plant
                </a>
            }
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mt-3">
            <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mt-3">
            <i class="fas fa-exclamation-triangle me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="plants-grid mt-4">
        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <div style="font-size: 4rem; opacity:0.3;">🌱</div>
                <h4 class="text-muted">No active plants</h4>
                @if (!isEmployee)
                {
                    <p class="text-muted">Add your first plant to start tracking growth.</p>
                    <a href="@Url.Action("Add", "Plants")" class="btn btn-success mt-2">
                        <i class="fas fa-plus me-1"></i>Add First Plant
                    </a>
                }
            </div>
        }
        @foreach (var plant in Model)
        {
            bool canHarvest = plant.GrowthStagePercent >= 100;

            <div class="plant-card mb-3 @(canHarvest ? "border border-warning border-2" : "")">
                @if (canHarvest)
                {
                    <div class="alert alert-warning py-1 px-3 mb-2 d-flex align-items-center justify-content-between">
                        <span><i class="fas fa-star me-1"></i><strong>Ready to Harvest!</strong></span>
                        <span class="badge bg-warning text-dark">100% Grown</span>
                    </div>
                }

                <div class="plant-header d-flex justify-content-between align-items-center">
                    <h3>@plant.Name</h3>
                    <span class="plant-type">@plant.PlantType</span>
                </div>

                @if (plant.Field != null)
                {
                    <div class="mb-1">
                        <small class="text-muted">
                            <i class="fas fa-map-marked-alt me-1"></i>
                            <strong>@plant.Field.Name</strong> — @plant.Field.City (@plant.Field.SizeInDecars dec.)
                        </small>
                    </div>
                }

                <div class="plant-date">
                    <i class="fas fa-calendar"></i>
                    <span>Planted: @plant.PlantedDate.ToString("d")</span>
                    @if (plant.CurrentTrackingDate.HasValue)
                    {
                        <span class="ms-2 text-muted small">| Tracked: @plant.CurrentTrackingDate.Value.ToString("d")</span>
                    }
                </div>

                <div class="growth-info">
                    <div class="growth-label d-flex justify-content-between">
                        <span>Growth Progress</span>
                        <span class="growth-percent fw-bold @(canHarvest ? "text-warning" : "")">
                            @plant.GrowthStagePercent%
                        </span>
                    </div>
                    <div class="progress" style="height:12px; background:#e6e6e6; border-radius:6px;">
                        <div class="progress-bar @(canHarvest ? "bg-warning" : "bg-success") progress-bar-striped"
                             role="progressbar"
                             style="width:@plant.GrowthStagePercent%"
                             aria-valuenow="@plant.GrowthStagePercent"
                             aria-valuemin="0"
                             aria-valuemax="100">
                        </div>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(plant.NextTask))
                {
                    <div class="next-task-box mt-2 d-flex align-items-start">
                        <i class="fas fa-info-circle me-2"></i>
                        <div>
                            <span class="task-label">Next Task</span>
                            <div class="task-text">@plant.NextTask</div>
                        </div>
                    </div>
                }

                @if (!string.IsNullOrEmpty(plant.Notes))
                {
                    <div class="notes-section mt-2">
                        <p class="notes-title">Notes</p>
                        <p class="notes-text">@plant.Notes</p>
                    </div>
                }

                @if (!string.IsNullOrEmpty(plant.Field?.SoilType) || !string.IsNullOrEmpty(plant.Field?.SunlightExposure) || plant.WateringFrequencyDays.HasValue)
                {
                    <div class="agronomic-section mt-3 pt-3" style="border-top: 1px solid #e6e6e6;">
                        <div class="agronomic-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 8px; font-size: 0.85rem;">
                            @if (!string.IsNullOrEmpty(plant.Field?.SoilType))
                            {
                                <div class="detail-item">
                                    <span class="detail-label">Soil:</span>
                                    <span class="detail-value">@plant.Field.SoilType</span>
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(plant.Field?.SunlightExposure))
                            {
                                <div class="detail-item">
                                    <span class="detail-label">Sunlight:</span>
                                    <span class="detail-value">@plant.Field.SunlightExposure</span>
                                </div>
                            }
                            @if (plant.Field?.AverageTemperatureCelsius != null)
                            {
                                <div class="detail-item">
                                    <span class="detail-label">Avg Temp:</span>
                                    <span class="detail-value">@plant.Field.AverageTemperatureCelsius.ToString("F1")°C</span>
                                </div>
                            }
                            @if (plant.WateringFrequencyDays.HasValue)
                            {
                                <div class="detail-item">
                                    <span class="detail-label">Watering:</span>
                                    <span class="detail-value">Every @plant.WateringFrequencyDays days</span>
                                </div>
                            }
                        </div>
                        @{
                            // Watering Frequency Suggestion
                            var cropType = plant.PlantType ?? "";
                            int suggestedWatering = cropType switch {
                                "Wheat" or "Rye" or "Barley" or "Oats" => 7,
                                "Corn (Maize)" or "Sorghum" or "Millet" => 5,
                                "Rice" => 1,
                                "Potato" or "Sweet Potato" or "Cassava" => 4,
                                "Carrot" or "Beetroot" or "Turnip" or "Radish" => 3,
                                "Tomato" or "Cucumber" or "Bell Pepper" or "Chili Pepper" or "Eggplant" => 2,
                                "Onion" or "Garlic" or "Cabbage" or "Broccoli" or "Cauliflower" => 4,
                                "Lettuce" or "Spinach" or "Zucchini" => 2,
                                "Beans (Green Beans)" or "Peas" or "Lentils" or "Chickpeas" or "Soybean" => 4,
                                "Strawberry" or "Watermelon" or "Melon" or "Pumpkin" or "Squash" => 3,
                                "Sunflower" or "Rapeseed (Canola)" or "Cotton" or "Sugar Beet" or "Sugarcane" => 5,
                                "Basil" or "Parsley" or "Dill" or "Mint" or "Oregano" or "Thyme" => 2,
                                "Alfalfa" or "Clover" or "Tobacco" => 6,
                                _ => 4
                            };
                            bool wateringOk = plant.WateringFrequencyDays.HasValue && plant.WateringFrequencyDays.Value <= suggestedWatering;
                        }
                        <div class="mt-2 p-2 rounded" style="background: @(wateringOk ? "#d4edda" : "#fff3cd"); border: 1px solid @(wateringOk ? "#c3e6cb" : "#ffc107"); font-size:0.82rem;">
                            <i class="fas fa-tint me-1" style="color: @(wateringOk ? "#28a745" : "#e67e22");"></i>
                            <strong>Watering Suggestion:</strong> For <em>@cropType</em>, water every <strong>@suggestedWatering day(s)</strong> for best health.
                            @if (plant.WateringFrequencyDays.HasValue)
                            {
                                @if (wateringOk)
                                {
                                    <span class="text-success ms-1">✅ Your schedule looks good!</span>
                                }
                                else
                                {
                                    <span class="text-warning ms-1">⚠️ Consider watering more frequently.</span>
                                }
                            }
                        </div>
                    </div>
                }

                <!-- ACTION BUTTONS -->
                <div class="mt-3 d-flex gap-2 action-row flex-wrap">
                    @* Edit - Boss, Manager, Admin, IT, or non-company user (not Employee) *@
                    @if (!isEmployee)
                    {
                        <a class="btn btn-sm btn-outline-primary action-btn" href="@Url.Action("Edit", "Plants", new { id = plant.Id })">
                            <i class="fas fa-edit"></i> Edit
                        </a>
                    }

                    @* Harvest - available to ALL if 100% grown. Hide disabled button for Manager/Admin/IT *@
                    @if (canHarvest)
                    {
                        <form asp-action="Harvest" method="post" style="display:inline-block;">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@plant.Id" />
                            <button type="submit" class="btn btn-sm btn-warning action-btn fw-bold"
                                    onclick="return confirm('Harvest @plant.Name? This will record the yield and free the field.');">
                                <i class="fas fa-wheat-alt"></i> 🌾 HARVEST
                            </button>
                        </form>
                    }
                    else if (!isManager && !isAdmin && !isIT)
                    {
                        @* Show disabled harvest only for Boss, Employee, and non-company users *@
                        <button class="btn btn-sm btn-outline-secondary action-btn" disabled
                                title="Can only harvest at 100% growth. Currently @plant.GrowthStagePercent%.">
                            <i class="fas fa-lock"></i> Harvest (@plant.GrowthStagePercent%)
                        </button>
                    }

                    @* Delete - Boss (company) OR non-company users (User/Admin/IT) *@
                    @if (canDelete)
                    {
                        <form asp-action="Delete" method="post" style="display:inline-block;">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@plant.Id" />
                            <button type="submit" class="btn btn-sm btn-danger action-btn"
                                    onclick="return confirm('Permanently delete this plant?')">
                                <i class="fas fa-trash"></i> Delete
                            </button>
                        </form>
                    }
                </div>
            </div>
        }
    </div>
</div>
