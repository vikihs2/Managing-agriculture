@model ManagingAgriculture.Models.PlantCreateViewModel
@{
    ViewData["Title"] = "Edit Plant";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="card mx-auto shadow-sm" style="max-width:800px;">
        <div class="card-header bg-success text-white">
            <h3 class="card-title mb-0"><i class="fas fa-seedling"></i> Edit Plant</h3>
        </div>
        <div class="card-body">
            
            @if (ViewBag.PlantStatus != null)
            {
                <div class="alert @(ViewBag.PlantStatus.Contains("Healthy") ? "alert-success" : ViewBag.PlantStatus.Contains("Stressed") ? "alert-warning" : "alert-danger")">
                    <strong>Plant Health Status: @ViewBag.PlantStatus</strong>
                </div>
            }

            @if (ViewBag.RecommendedSoil != null)
            {
                <div class="alert alert-info">
                    <h6 class="alert-heading">📋 Recommended Conditions for @Model.CropType</h6>
                    <hr class="my-2" />
                    <div class="row">
                        <div class="col-md-6 mb-2">
                            <strong>🌱 Soil:</strong> @ViewBag.RecommendedSoil
                        </div>
                        <div class="col-md-6 mb-2">
                            <strong>☀️ Sunlight:</strong> @ViewBag.RecommendedSunlight
                        </div>
                        <div class="col-md-6 mb-2">
                            <strong>🌡️ Temperature:</strong> @ViewBag.RecommendedTemperature
                        </div>
                        <div class="col-md-6 mb-2">
                            <strong>💧 Watering:</strong> @ViewBag.RecommendedWater
                        </div>
                    </div>
                </div>
            }

            <form asp-action="Edit" asp-route-id="@ViewBag.Id" method="post" id="editPlantForm">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Name" class="form-label fw-bold">Plant Name</label>
                        <input asp-for="Name" class="form-control" placeholder="e.g. My Tomato Garden" required />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>
                
                    <div class="col-md-6 mb-3">
                        <label asp-for="CropType" class="form-label fw-bold">Crop Type</label>
                        <input asp-for="CropType" class="form-control" readonly style="background-color: #e9ecef;" />
                        <small class="form-text text-muted">Crop type is locked and cannot be changed after planting</small>
                        <span asp-validation-for="CropType" class="text-danger"></span>
                    </div>
                </div>

                <!-- Field Selection (Required) -->
                <div class="mb-3">
                    <label asp-for="FieldId" class="form-label fw-bold">Field</label>
                    <select asp-for="FieldId" class="form-control" required>
                        <option value="">-- Select a field --</option>
                        @if (ViewBag.Fields != null)
                        {
                            @foreach (var field in ViewBag.Fields)
                            {
                                <option value="@field.Id" selected="@(Model.FieldId == field.Id)">@field.Name (@field.SizeInDecars decars, @field.City)</option>
                            }
                        }
                    </select>
                    <span asp-validation-for="FieldId" class="text-danger"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="PlantedDate" class="form-label fw-bold">Plant Date</label>
                        <input asp-for="PlantedDate" class="form-control" type="date" required />
                        <span asp-validation-for="PlantedDate" class="text-danger"></span>
                    </div>
                    
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="CurrentTrackingDate" class="form-label fw-bold">Current Tracking Date</label>
                        <input asp-for="CurrentTrackingDate" class="form-control" type="date" />
                        <small class="form-text text-muted">Leave empty for today's date</small>
                        <span asp-validation-for="CurrentTrackingDate" class="text-danger"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Approximate Growth (%)</label>
                        <div class="progress" style="height: 25px;">
                            <div class="progress-bar progress-bar-striped progress-bar-animated bg-success" role="progressbar" style="width: @Model.GrowthStage%;" aria-valuenow="@Model.GrowthStage" aria-valuemin="0" aria-valuemax="100">@Model.GrowthStage%</div>
                        </div>
                        <input type="hidden" asp-for="GrowthStage" id="growthStageValue" />
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="WateringFrequencyDays" class="form-label fw-bold">Watering Frequency (days)</label>
                        <input asp-for="WateringFrequencyDays" class="form-control" type="number" min="1" max="365" placeholder="e.g., 2" required />
                        <span asp-validation-for="WateringFrequencyDays" class="text-danger"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="IsIndoor" class="form-label fw-bold">
                            <input type="checkbox" asp-for="IsIndoor" />
                            Indoor Plant
                        </label>
                        <span asp-validation-for="IsIndoor" class="text-danger"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="NextTask" class="form-label fw-bold">Next Task</label>
                    <input asp-for="NextTask" class="form-control" placeholder="e.g. Water plants, Apply fertilizer" />
                    <span asp-validation-for="NextTask" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Notes" class="form-label fw-bold">Notes</label>
                    <textarea asp-for="Notes" class="form-control" rows="3" placeholder="Additional observations..."></textarea>
                    <span asp-validation-for="Notes" class="text-danger"></span>
                </div>

                <div class="d-flex justify-content-between mt-4">
                    <a class="btn btn-outline-secondary" href="@Url.Action("Index", "Plants")">Back to List</a>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary px-4">Update Plant</button>
                        <a asp-action="Harvest" asp-route-id="@ViewBag.Id" class="btn btn-warning"><i class="fas fa-cut"></i> Harvest</a>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
}
