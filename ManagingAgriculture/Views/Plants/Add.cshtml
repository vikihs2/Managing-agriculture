@model ManagingAgriculture.Models.PlantCreateViewModel
@{
    ViewData["Title"] = "Add Plant";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="card mx-auto" style="max-width:750px;">
        <div class="card-body">
            <h3 class="card-title mb-3">Add Plant</h3>
            <form asp-action="Add" method="post" id="plantForm">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="mb-3">
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name" class="form-control" placeholder="e.g. Tomato Garden A" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <!-- Searchable Crop Type Dropdown -->
                <div class="mb-3">
                    <label asp-for="CropType" class="form-label fw-bold">Crop Type</label>
                    <input asp-for="CropType" id="cropInput" class="form-control" placeholder="Type to search crop..." list="cropList" />
                    <datalist id="cropList">
                        @if(ViewBag.CropCategories != null)
                        {
                            foreach (var category in (Dictionary<string, List<string>>)ViewBag.CropCategories)
                            {
                                <optgroup label="@category.Key">
                                    @foreach(var crop in category.Value)
                                    {
                                        <option value="@crop">@crop</option>
                                    }
                                </optgroup>
                            }
                        }
                    </datalist>
                    <span asp-validation-for="CropType" class="text-danger"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="PlantedDate" class="form-label"></label>
                        <input asp-for="PlantedDate" class="form-control" type="date" />
                        <span asp-validation-for="PlantedDate" class="text-danger"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="CurrentTrackingDate" class="form-label"></label>
                        <input asp-for="CurrentTrackingDate" class="form-control" type="date" />
                        <small class="form-text text-muted">Leave empty for today's date</small>
                        <span asp-validation-for="CurrentTrackingDate" class="text-danger"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Growth Stage (Calculated)</label>
                        <div class="progress" style="height: 25px; background-color: #f0f0f0;">
                            <div id="growthBar" class="progress-bar progress-bar-striped bg-success" role="progressbar" style="width: 0%;" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100">0%</div>
                        </div>
                        <input type="hidden" asp-for="GrowthStage" id="growthStageInput" />
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="NextTask" class="form-label">Next Task (Memo)</label>
                    <input asp-for="NextTask" class="form-control" placeholder="e.g. Water plants, Apply fertilizer" />
                    <span asp-validation-for="NextTask" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Notes" class="form-label">Notes (Memo)</label>
                    <textarea asp-for="Notes" class="form-control" rows="3" placeholder="Additional observations..."></textarea>
                    <span asp-validation-for="Notes" class="text-danger"></span>
                </div>

                <hr class="my-4" />
                <h5 class="mb-3">Environmental Inputs (For Growth Algorithm)</h5>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="SoilType" class="form-label">Soil Type</label>
                        <select asp-for="SoilType" class="form-select" onchange="updateGrowth()">
                            <option value="">-- Select Soil --</option>
                            <option value="Clay">Clay</option>
                            <option value="Sandy">Sandy</option>
                            <option value="Loamy">Loamy</option>
                            <option value="Silty">Silty</option>
                            <option value="Peaty">Peaty</option>
                            <option value="Chalky">Chalky</option>
                        </select>
                        <span asp-validation-for="SoilType" class="text-danger"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="SunlightExposure" class="form-label">Sunlight Exposure</label>
                        <select asp-for="SunlightExposure" class="form-select" onchange="updateGrowth()">
                            <option value="">-- Select Sunlight --</option>
                            <option value="Full Sun">Full Sun (6+ hrs)</option>
                            <option value="Partial Sun">Partial Sun (3-6 hrs)</option>
                            <option value="Partial Shade">Partial Shade (1-3 hrs)</option>
                            <option value="Full Shade">Full Shade (&lt;1 hr)</option>
                        </select>
                        <span asp-validation-for="SunlightExposure" class="text-danger"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <div class="form-check">
                            <input asp-for="IsIndoor" class="form-check-input" type="checkbox" onchange="updateGrowth()" />
                            <label asp-for="IsIndoor" class="form-check-label">
                                Indoor Plant
                            </label>
                        </div>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="AvgTemperatureCelsius" class="form-label">Avg Temperature (°C)</label>
                        <input asp-for="AvgTemperatureCelsius" class="form-control" type="number" min="-50" max="60" step="0.5" placeholder="e.g. 22.5" onchange="updateGrowth()" />
                        <span asp-validation-for="AvgTemperatureCelsius" class="text-danger"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="WateringFrequencyDays" class="form-label">Watering Frequency (days)</label>
                        <input asp-for="WateringFrequencyDays" class="form-control" type="number" min="0" max="365" placeholder="e.g. 2 days" onchange="updateGrowth()" />
                        <span asp-validation-for="WateringFrequencyDays" class="text-danger"></span>
                    </div>
                </div>

                <div class="d-flex justify-content-between mt-4">
                    <a class="btn btn-secondary" href="@Url.Action("Index", "Plants")"><i class="fas fa-times"></i> Cancel</a>
                    <button type="submit" class="btn btn-success"><i class="fas fa-save"></i> Create Plant</button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .form-select { border: 1px solid #ced4da; padding: 0.375rem 0.75rem; }
    .progress { height: 25px; }
</style>

@section Scripts {
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    <script>
        // Simple client-side growth display (actual calculation happens on server)
        function updateGrowth() {
            // This is just for display - the real calculation happens server-side
            const plantedDate = new Date(document.querySelector('input[name="PlantedDate"]').value);
            const currentDate = new Date(document.querySelector('input[name="CurrentTrackingDate"]').value);
            
            if (!plantedDate || !currentDate || plantedDate > currentDate) {
                document.getElementById('growthBar').style.width = '0%';
                document.getElementById('growthBar').textContent = '0%';
                document.getElementById('growthStageInput').value = 0;
                return;
            }
            
            const elapsed = (currentDate - plantedDate) / (1000 * 60 * 60 * 24);
            const estimatedGrowth = Math.min(Math.round((elapsed / 90) * 100), 100); // Assume 90-day crop as default
            
            document.getElementById('growthBar').style.width = estimatedGrowth + '%';
            document.getElementById('growthBar').textContent = estimatedGrowth + '%';
            document.getElementById('growthStageInput').value = estimatedGrowth;
        }
        
        // Call updateGrowth on date changes
        document.querySelector('input[name="PlantedDate"]').addEventListener('change', updateGrowth);
        document.querySelector('input[name="CurrentTrackingDate"]').addEventListener('change', updateGrowth);
    </script>
}
