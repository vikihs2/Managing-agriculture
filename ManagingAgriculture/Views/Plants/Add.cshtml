@model ManagingAgriculture.Models.PlantCreateViewModel
@{
    ViewData["Title"] = "Add Plant";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
<link href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css" rel="stylesheet" />

<div class="container mt-4">
    <div class="card mx-auto" style="max-width:750px;">
        <div class="card-body">
            <h3 class="card-title mb-3">Add Plant</h3>
            <form asp-action="Add" method="post" id="plantForm">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="mb-3">
                    <label asp-for="Name" class="form-label fw-bold">Plant Name</label>
                    <input asp-for="Name" class="form-control" placeholder="e.g. Tomato Garden A" required />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <!-- Field Selection (Required) -->
                <div class="mb-3">
                    <label asp-for="FieldId" class="form-label fw-bold">Field</label>
                    <select asp-for="FieldId" class="form-control" required>
                        <option value="">-- Select a field --</option>
                        @if (ViewBag.Fields != null)
                        {
                            @foreach (var field in ViewBag.Fields)
                            {
                                <option value="@field.Id">@field.Name (@field.SizeInDecars decars, @field.City)</option>
                            }
                        }
                    </select>
                    <span asp-validation-for="FieldId" class="text-danger"></span>
                </div>

                <!-- Searchable Crop Type Dropdown (Required, NOT free text) -->
                <div class="mb-3">
                    <label asp-for="CropType" class="form-label fw-bold">Crop Type</label>
                    <select asp-for="CropType" class="form-control select2" required>
                        <option value="">-- Select crop type --</option>
                        @if(ViewBag.CropCategories != null)
                        {
                            foreach (var category in (Dictionary<string, List<string>>)ViewBag.CropCategories)
                            {
                                <optgroup label="@category.Key">
                                    @foreach(var crop in category.Value)
                                    {
                                        <option value="@crop">@crop</option>
                                    }
                                </optgroup>
                            }
                        }
                    </select>
                    <span asp-validation-for="CropType" class="text-danger"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="PlantedDate" class="form-label fw-bold">Plant Date</label>
                        <input asp-for="PlantedDate" class="form-control" type="date" required />
                        <span asp-validation-for="PlantedDate" class="text-danger"></span>
                    </div>
                    
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="CurrentTrackingDate" class="form-label fw-bold">Current Tracking Date</label>
                        <input asp-for="CurrentTrackingDate" class="form-control" type="date" />
                        <small class="form-text text-muted">Leave empty for today's date</small>
                        <span asp-validation-for="CurrentTrackingDate" class="text-danger"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Approximate Growth (%)</label>
                        <div class="progress" style="height: 25px; background-color: #f0f0f0;">
                            <div id="growthBar" class="progress-bar progress-bar-striped bg-success" role="progressbar" style="width: 0%;" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100">0%</div>
                        </div>
                        <input type="hidden" asp-for="GrowthStage" id="growthStageInput" />
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="WateringFrequencyDays" class="form-label fw-bold">Watering Frequency (days)</label>
                    <input asp-for="WateringFrequencyDays" class="form-control" type="number" min="1" max="365" placeholder="e.g., 2" required />
                    <span asp-validation-for="WateringFrequencyDays" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="NextTask" class="form-label fw-bold">Next Task</label>
                    <input asp-for="NextTask" class="form-control" placeholder="e.g. Water plants, Apply fertilizer" />
                    <span asp-validation-for="NextTask" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Notes" class="form-label fw-bold">Notes</label>
                    <textarea asp-for="Notes" class="form-control" rows="3" placeholder="Additional observations..."></textarea>
                    <span asp-validation-for="Notes" class="text-danger"></span>
                </div>

                <div class="d-flex justify-content-between mt-4">
                    <a class="btn btn-secondary" href="@Url.Action("Index", "Plants")"><i class="fas fa-times"></i> Cancel</a>
                    <button type="submit" class="btn btn-success"><i class="fas fa-save"></i> Create Plant</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script>
        function updateGrowth() {
            const plantedDate = new Date(document.querySelector('input[name="PlantedDate"]').value);
            const currentDate = new Date(document.querySelector('input[name="CurrentTrackingDate"]').value);
            
            if (!plantedDate || !currentDate || plantedDate > currentDate) {
                document.getElementById('growthBar').style.width = '0%';
                document.getElementById('growthBar').textContent = '0%';
                document.getElementById('growthStageInput').value = 0;
                return;
            }
            
            const elapsed = (currentDate - plantedDate) / (1000 * 60 * 60 * 24);
            const estimatedGrowth = Math.min(Math.round((elapsed / 90) * 100), 100);
            
            document.getElementById('growthBar').style.width = estimatedGrowth + '%';
            document.getElementById('growthBar').textContent = estimatedGrowth + '%';
            document.getElementById('growthStageInput').value = estimatedGrowth;
        }
        
        document.querySelector('input[name="PlantedDate"]').addEventListener('change', updateGrowth);
        document.querySelector('input[name="CurrentTrackingDate"]').addEventListener('change', updateGrowth);

        $(document).ready(function() {
            $('.select2').select2({
                theme: 'bootstrap-5',
                placeholder: "-- Select crop type --",
                allowClear: true
            });
        });
    </script>
}
