@model IEnumerable<ManagingAgriculture.Models.ContactForm>
@{
    ViewData["Title"] = "IT Support";
}

<div class="dashboard-container">
    <div class="page-header">
        <div>
            <h2>🛠 IT Support Panel</h2>
            <p class="subtitle">Technical Maintenance & System Diagnostics</p>
        </div>
    </div>

    <!-- Diagnostics Card -->
    <div class="row">
        <div class="col-md-4">
            <div class="card mb-4 shadow-sm">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0"><i class="fas fa-server me-2"></i>System Diagnostics</h5>
                </div>
                <div class="card-body">
                    <p>Status: <span id="diagStatus" class="text-success fw-bold">Healthy ✅</span></p>
                    <button id="runDiagsBtn" class="btn btn-info text-white w-100">
                        <i class="fas fa-play me-1"></i>Run Diagnostics
                    </button>
                    <div id="diagnosticsResult" class="mt-3" style="display:none;">
                        <div class="alert alert-info p-2">
                            <strong>Diagnostics Report:</strong>
                            <table class="table table-sm table-striped mt-2 mb-0">
                                <tbody id="diagTable"></tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-8">
            <div class="card mb-4 shadow-sm">
                <div class="card-header bg-dark text-white">
                    <h5 class="mb-0"><i class="fas fa-info-circle me-2"></i>About IT Support Access</h5>
                </div>
                <div class="card-body">
                    <ul class="list-unstyled mb-0">
                        <li class="mb-2"><i class="fas fa-check text-success me-2"></i>Run system diagnostics to verify DB connectivity</li>
                        <li class="mb-2"><i class="fas fa-check text-success me-2"></i>View and reply to support tickets in the <strong>Inbox</strong></li>
                        <li class="mb-2"><i class="fas fa-check text-success me-2"></i>Access all public sections of the app</li>
                        <li class="mb-2"><i class="fas fa-check text-success me-2"></i>Manage fields in the Fields section</li>
                    </ul>
                    <hr/>
                    <small class="text-muted">
                        <i class="fas fa-lightbulb me-1 text-warning"></i>
                        <strong>DB Connection:</strong> Click "Run Diagnostics" — if the database is connected, you will see real counts for Users, Plants, etc.
                        If you see errors, the DB connection is down.
                    </small>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('runDiagsBtn').addEventListener('click', async function() {
            const btn = this;
            const originalHtml = btn.innerHTML;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i>Running...';
            btn.disabled = true;

            try {
                const response = await fetch('/ITSupport/RunDiagnostics', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                });

                const data = await response.json();
                
                if (data.success) {
                    const diagTable = document.getElementById('diagTable');
                    diagTable.innerHTML = '';
                    
                    for (const [key, value] of Object.entries(data.diagnostics)) {
                        const row = document.createElement('tr');
                        let displayValue = value;
                        
                        if (key === 'Timestamp') {
                            displayValue = new Date(value).toLocaleString();
                        } else if (typeof value === 'number') {
                            displayValue = value.toLocaleString();
                        }
                        
                        const isStatus = key.includes('Status') || key.includes('Database');
                        row.innerHTML = `<td><strong>${key}:</strong></td><td class="${isStatus ? 'text-success fw-bold' : ''}">${displayValue}</td>`;
                        diagTable.appendChild(row);
                    }
                    
                    document.getElementById('diagnosticsResult').style.display = 'block';
                    document.getElementById('diagStatus').textContent = 'Healthy ✅';
                    document.getElementById('diagStatus').className = 'text-success fw-bold';
                } else {
                    document.getElementById('diagStatus').textContent = 'Error ❌';
                    document.getElementById('diagStatus').className = 'text-danger fw-bold';
                    alert('Diagnostic failed: ' + data.error);
                }
            } catch (error) {
                console.error('Error:', error);
                document.getElementById('diagStatus').textContent = 'Error ❌';
                document.getElementById('diagStatus').className = 'text-danger fw-bold';
                alert('Failed to run diagnostics. Check your connection.');
            } finally {
                btn.innerHTML = originalHtml;
                btn.disabled = false;
            }
        });
    </script>
}
