@{
    Layout = null;
    ViewData["Title"] = "AgroCore - Home";
}

<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <style>
        /* Reset */
        *{box-sizing:border-box;margin:0;padding:0}
        body{font-family: 'Helvetica Neue', Arial, sans-serif;color:#222;background:#fff}
    /* Avoid re-declaring ViewData inside head */
        /* Home-only: Login and Register buttons */
        .btn-login{background:#74c69d;color:#fff;border:none;padding:6px 12px;border-radius:6px;cursor:pointer;text-decoration:none;font-size:13px;font-weight:600;transition:all 0.25s ease}
        .btn-login:hover{background:#58b385;}
        .btn-register{background:#ff9800;color:#fff;border:none;padding:6px 12px;border-radius:6px;cursor:pointer;text-decoration:none;font-size:13px;font-weight:600;transition:all 0.25s ease}
        .btn-register:hover{background:#e68a00;}

        /* Hero */
        .hero{height:560px;background:url('/images/homeBackground.webp') center/cover no-repeat;position:relative;display:flex;flex-direction:column;align-items:center;justify-content:center;padding-top:72px;gap:8px}
        .hero::before{content:"";position:absolute;inset:0;background:linear-gradient(180deg,rgba(0,0,0,0.45),rgba(0,0,0,0.65));}
        .hero-inner{position:relative;z-index:2;text-align:center;color:#fff;max-width:1100px;padding:20px}
        .hero h1{font-family: 'Georgia', serif;font-size:46px;line-height:1.04;font-weight:900;margin-bottom:12px;text-shadow:0 10px 20px rgba(0,0,0,0.6)}
        .hero h1 .accent{color:var(--accent-green);display:inline-block}
        .hero p{max-width:760px;margin:0 auto 18px;color:rgba(255,255,255,0.96);font-size:16px;text-shadow:0 6px 18px rgba(0,0,0,0.5)}
        .hero .btn-primary{background:#74c69d;color:#fff;border:none;padding:6px 12px;border-radius:6px;font-size:13px;font-weight:600;transition:all 0.2s ease;text-decoration:none;display:inline-block;}
        .hero .btn-primary:hover{background:#58b385;}

        /* Center stats: stacked below hero text */
        .stats{position:relative;left:auto;top:auto;transform:none;display:flex;gap:48px;z-index:2;justify-content:center;align-items:center;width:100%;margin-top:18px}
        .stat{color:#fff;text-align:center;min-width:120px}
        .stat .num{font-size:22px;font-weight:800}
        .stat .label{opacity:0.9;margin-top:6px;font-size:12px}
        /* Hero CTA - Bigger "Start Tracking Now" */
        .hero-cta{display:flex;justify-content:center;margin-top:14px;z-index:2;width:100%}
        .hero-cta a{background:#74c69d;color:#fff;border:none;padding:12px 28px;border-radius:12px;text-decoration:none;display:inline-block;font-size:18px;font-weight:700;transition:all 0.25s ease;box-shadow: 0 4px 15px rgba(0,0,0,0.2);}
        .hero-cta a:hover{background:#58b385;transform: translateY(-2px);box-shadow: 0 6px 20px rgba(0,0,0,0.3);}

        /* Content cards */
        .content-section{padding:48px 16px;background:#fbf7f2}
        .section-title{max-width:1100px;margin:0 auto 18px;text-align:center}
        .section-title h2{font-family:'Georgia',serif;font-size:28px;color:#2b2b2b}
        .cards{max-width:1100px;margin:0 auto;display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
        .card{background:#fff;border-radius:10px;padding:18px;border:1px solid rgba(0,0,0,0.06);box-shadow:0 6px 18px rgba(15,15,15,0.02);min-height:110px}
        .card .icon{width:40px;height:40;background:#eef7ea;border-radius:8px;display:inline-flex;align-items:center;justify-content:center;margin-bottom:12px}
        .card h3{font-size:18px;margin-bottom:8px;color:#2b2b2b}
        .card p{color:#6b6b6b;font-size:13px}

        /* CTA dark strip */
        .cta{background:#342d26;color:#fff;padding:48px 20px;text-align:center}
        .cta h2{font-family:'Georgia',serif;font-size:24px;margin-bottom:12px}
        .cta p{opacity:0.9;margin-bottom:16px}
        .cta .cta-actions{display:flex;gap:12px;justify-content:center;flex-wrap:wrap}
        .cta .btn-primary{background:#74c69d;border:none;padding:6px 12px;border-radius:6px;color:#fff;text-decoration:none;font-size:13px;font-weight:600;transition:all 0.25s ease}
        .cta .btn-primary:hover{background:#58b385;}
        .cta .btn-outline{background:#ff9800;border:none;color:#fff;padding:6px 12px;border-radius:6px;text-decoration:none;font-size:13px;font-weight:600;transition:all 0.25s ease}
        .cta .btn-outline:hover{background:#e68a00;}

        /* hero accent color for last words */
        .hero h1 .accent{ color: var(--accent-green); }

        /* style Dashboard JUST on the home page (keep Sign out unstyled) */
        .top-nav .nav-right .btn-outline, .top-nav .nav-right .btn-dashboard {
            background:#74c69d;
            border: none;
            color: #fff;
        }
        .top-nav .nav-right .btn-outline:hover, .top-nav .nav-right .btn-dashboard:hover {
            background:#58b385;
        }

        /* Top nav */
        .top-nav{height:72px;display:flex;align-items:center;justify-content:space-between;padding:0 20px;position:fixed;left:0;right:0;top:0;z-index:100;background:rgba(0,0,0,0.25);-webkit-backdrop-filter: blur(6px);backdrop-filter: blur(6px);color:#fff}
        .nav-left{display:flex;align-items:center;gap:10px}
        .logo-badge{width:42px;height:42px;border-radius:8px;background:rgba(255,255,255,0.06);display:inline-flex;align-items:center;justify-content:center;font-size:20px}
        .brand{font-weight:700;color:#fff;margin-left:0;display:inline-flex;align-items:center;justify-content:center}
        .nav-right{display:flex;align-items:center;gap:12px}

        /* Home page: style Dashboard to match sign out (only on home) */
        .top-nav .nav-right .btn-outline, .top-nav .nav-right .btn-dashboard {
            background:#74c69d;
            border: none;
            color: #fff;
            padding: 6px 12px;
            font-size: 13px;
            font-weight: 600;
            border-radius: 6px;
            text-decoration: none;
            transition: all 0.25s ease;
        }
        .top-nav .nav-right .btn-outline:hover, .top-nav .nav-right .btn-dashboard:hover{
            background:#58b385;
        }

        /* Home-specific: style Sign out button (orange) and remove default outline */
        .top-nav .nav-right .btn-signout {
            background: #ff9800; /* orange */
            border: none;
            color: #fff;
            padding: 6px 12px;
            font-size: 13px;
            font-weight: 600;
            border-radius: 6px;
            outline: none;
            cursor: pointer;
            transition: all 0.25s ease;
        }
        .top-nav .nav-right .btn-signout:hover {
            background: #e68a00;
            color: #fff;
        }

        /* CTA dark strip */
        .cta{background:#292117;color:#fff;padding:48px 20px;text-align:center}
        .cta h2{font-family:'Georgia',serif;font-size:24px;margin-bottom:12px}
        .cta p{opacity:0.9;margin-bottom:16px}
        .cta .cta-actions{display:flex;gap:12px;justify-content:center;flex-wrap:wrap}
        /* CTA: use specific green for primary buttons (match "Better Yields") */
        .cta .btn-primary{background:#74c69d;border:none;padding:6px 12px;border-radius:6px;color:#fff;text-decoration:none;font-size:13px;font-weight:600;transition:all 0.25s ease}
        .cta .btn-primary:hover{background:#58b385;}
        /* Contact button: same style as Register button (filled orange) */
        .cta .btn-outline{background:#ff9800;border:none;color:#fff;padding:6px 12px;border-radius:6px;text-decoration:none;font-size:13px;font-weight:600;transition:all 0.25s ease}
        .cta .btn-outline:hover{background:#e68a00;}

        /* Footer */
        .site-footer{background:#1c1711;color:rgba(255,255,255,0.95);padding:28px 16px;border-top:1px solid rgba(255,255,255,0.15)}
        .footer-inner{max-width:1100px;margin:0 auto;display:flex;gap:20px;flex-wrap:wrap}
        .footer-col{flex:1;min-width:160px}
        .footer-col h4{color:#fff;margin-bottom:10px}
        .footer-col p,a{color:rgba(255,255,255,0.85);text-decoration:none;font-size:14px}

        /* Responsive (mobile-first) */
        @@media (max-width:1000px){
            .cards{grid-template-columns:repeat(2,1fr)}
            .hero{height:520px}
        }
        @@media (max-width:640px){
            .hero{height:420px;background-position:center top}
            .hero h1{font-size:28px}
            .hero p{font-size:14px}
            .stats{position:static;transform:none;left:auto;flex-direction:column;margin-top:14px;bottom:auto;gap:8px;align-items:center;justify-content:center;width:100%}
            .cards{grid-template-columns:1fr}
            .cta h2{font-size:20px}
            .top-nav{height:64px;padding:0 12px}
            .brand{font-size:18px}
            .logo-badge{width:38px;height:38px}
            .nav-right{gap:8px}
            .btn-login{padding:8px 10px;font-size:12px}
            .btn-register{padding:8px 10px;font-size:12px}
            .section-title h2{font-size:22px}
            .card h3{font-size:16px}
            .hero-cta a{padding:10px 16px;font-size:13px}
            .cta .btn-primary{padding:10px 16px;font-size:13px}
            .cta .btn-outline{padding:10px 16px;font-size:13px}
            .top-nav .nav-right .btn-dashboard{padding:8px 12px;font-size:12px}
            .top-nav .nav-right .btn-signout{padding:8px 12px;font-size:12px}
        }

        /* Simple fade-in animation classes (preserved) */
        .fade-in{animation:fadeIn 900ms ease both}
        @@keyframes fadeIn{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:none}}
    </style>
</head>
<body>

    <nav class="top-nav">
        <div class="nav-left">
            <div class="brand-emoji top-brand-emoji" aria-hidden="true">🌱</div>
            <div class="brand">AgroCore</div>
        </div>

        

        <div class="nav-right">
            @if (User?.Identity?.IsAuthenticated == true)
            {
                var email = User.Identity?.Name ?? User.FindFirst("email")?.Value ?? "";
                var name = "User";
                if (!string.IsNullOrEmpty(email) && email.Contains("@"))
                {
                    var raw = email.Split('@')[0];
                    name = raw.Length > 0 ? char.ToUpper(raw[0]) + raw.Substring(1) : raw;
                }

                if (User.IsInRole("SystemAdmin") || email.Equals("admin@gmail.com", StringComparison.OrdinalIgnoreCase))
                    name = "Admin";
                else if (User.IsInRole("ITSupport"))
                    name = "IT Support";
                else if (User.IsInRole("Boss"))
                    name = "Boss";
                else if (User.IsInRole("Manager"))
                    name = "Manager";
                <span style="font-size: 14px; font-weight: 600;">Welcome @name!</span>
                <a href="@Url.Action("Index", "Dashboard")" class="btn-dashboard">Dashboard</a>

                <form asp-controller="Account" asp-action="Logout" method="post" style="display:inline-block;">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-signout">Sign out</button>
                </form>
            }
            else
            {
                <a class="btn btn-login" href="@Url.Action("Login","Account")">Login</a>
                <a class="btn btn-register" href="@Url.Action("Register","Account")">Register</a>
            }
        </div>
    </nav>

    <header class="hero">
        <div class="hero-inner fade-in">
            <h1>Smarter Farming for <span style="color:#74c69d;">Better Yields</span></h1>
            <p>Manage your crops, resources and machinery in one simple platform. Track field conditions, irrigation, supplies, and daily farm operations.</p>
        </div>

        <div class="stats fade-in" style="animation-delay:200ms">
            <div class="stat">
                <div class="num">4K+</div>
                <div class="label">Farms Using the System</div>
            </div>
            <div class="stat">
                <div class="num">1.2M</div>
                <div class="label">Acres Tracked</div>
            </div>
            <div class="stat">
                <div class="num">95%</div>
                <div class="label">Satisfaction</div>
            </div>
        </div>
        <div class="hero-cta fade-in" style="animation-delay:320ms;">
            @if (User?.Identity?.IsAuthenticated == true)
            {
                <a href="@Url.Action("Index", "Plants")">Start Tracking Now</a>
            }
            else
            {
                <a href="@Url.Action("Register", "Account")">Start Tracking Now</a>
            }
        </div>
    </header>

    <section class="content-section">
        <div class="section-title fade-in">
            <h2>Everything You Need to Run Your Farm</h2>
            <p style="opacity:0.8">Simple, reliable tools designed for real farmers with real needs.</p>
        </div>

        <div class="cards">
            <div class="card fade-in">
                <div class="icon">🌱</div>
                <h3>Crop Management</h3>
                <p>Track planting schedules, growth stages, and harvest timelines for all your crops in one place.</p>
            </div>
            <div class="card fade-in">
                <div class="icon">💧</div>
                <h3>Irrigation Tracking</h3>
                <p>Monitor water usage and irrigation schedules to optimize your resources and reduce waste.</p>
            </div>
            <div class="card fade-in">
                <div class="icon">🔧</div>
                <h3>Machinery Logs</h3>
                <p>Keep records of equipment maintenance, fuel usage, and operational hours.</p>
            </div>
            <div class="card fade-in">
                <div class="icon">📡</div>
                <h3>Arduino Sensors</h3>
                <p>Monitor soil conditions and farm activity in real time using Arduino-powered smart sensors and automation.</p>
            </div>
            <div class="card fade-in">
                <div class="icon">📦</div>
                <h3>Inventory</h3>
                <p>Keep an accurate inventory of seeds, fertilizers, and other inputs for better procurement planning.</p>
            </div>
            <div class="card fade-in">
                <div class="icon">📊</div>
                <h3>Reporting</h3>
                <p>Generate harvest and resource usage reports for compliance and internal review.</p>
            </div>
        </div>
    </section>

    <section class="cta fade-in">
        <h2>Ready to Simplify Your Farm Operations?</h2>
        <p>Join thousands of farmers who trust our platform to manage their daily work, track resources, and grow their yields.</p>
        <div class="cta-actions">
            @if (User?.Identity?.IsAuthenticated == true)
            {
                <a href="@Url.Action("Index", "Plants")" class="btn-primary">Start Tracking Now</a>
            }
            else
            {
                <a href="@Url.Action("Register", "Account")" class="btn-primary">Start Tracking Now</a>
            }
            <a href="@Url.Action("Contact", "Home")" class="btn-outline">Contact Us</a>
        </div>
    </section>

    <footer class="site-footer">
        <div class="footer-inner">
            <div class="footer-col">
                <h4>AgroCore</h4>
                <p>Helping farmers manage their operations simply and effectively since 2025.</p>
            </div>
            <div class="footer-col">
                <h4>Quick Links</h4>
                <p>
                    <a href="@Url.Action("Index", "Dashboard")">Dashboard</a><br />
                    <a href="@Url.Action("Index", "Marketplace")">Marketplace</a><br />
                    <a href="@Url.Action("Index", "Resources")">Resources</a><br />
                    <a href="@Url.Action("Contact", "Home")">Support</a>
                </p>
            </div>
            <div class="footer-col">
                <h4>Contact</h4>
                <p><a href="mailto:victor.stefanov.highschool@buditel.bg">victor.stefanov.highschool@buditel.bg</a></p>
            </div>
        </div>
    </footer>

</body>
</html>