@using System.Linq
@model IEnumerable<ManagingAgriculture.Models.MarketplaceListing>
@{
    var approvedIds  = ViewBag.ApprovedListingIds  as HashSet<int> ?? new HashSet<int>();
    var pendingIds   = ViewBag.PendingListingIds   as HashSet<int> ?? new HashSet<int>();
    string currentUserId = ViewBag.CurrentUserId as string ?? "";
    bool canTransact = ViewBag.CanTransact as bool? ?? false;
}

<div class="marketplace-grid">
@if (!Model.Any())
{
    <div class="text-center py-5 text-muted w-100">
        <i class="fas fa-box-open fa-3x mb-3 opacity-25"></i>
        <p class="fs-5">No listings found. Be the first to post!</p>
    </div>
}
@foreach (var listing in Model)
{
    bool isMine     = listing.SellerUserId == currentUserId;
    bool approved   = approvedIds.Contains(listing.Id);
    bool pending    = pendingIds.Contains(listing.Id);

<div class="marketplace-card">
    @if (listing.ImageUrl != null && listing.ImageUrl.StartsWith("http"))
    {
        <img src="@listing.ImageUrl" alt="@listing.ItemName" class="marketplace-card-img" style="width:100%;height:160px;object-fit:cover;border-radius:8px 8px 0 0;" />
    }
    <div class="card-body p-3">
        <div class="d-flex justify-content-between align-items-start mb-1">
            <h5 class="card-title mb-0 fw-bold">@listing.ItemName</h5>
            <span class="badge bg-secondary">@listing.ConditionStatus</span>
        </div>
        <p class="text-muted small mb-1">
            @if (listing.EngineHours.HasValue)
            {
                <span><i class="fas fa-clock me-1"></i>@listing.EngineHours.Value.ToString("N0") h</span>
            }
        </p>
        @if (!string.IsNullOrWhiteSpace(listing.Description))
        {
            <p class="card-text small text-muted mb-2" style="font-size:0.82rem">@listing.Description</p>
        }
        <div class="mb-2">
            @if (listing.SalePrice.HasValue && listing.SalePrice > 0)
            {
                <span class="fw-bold text-success fs-5">$@listing.SalePrice.Value.ToString("N0")</span>
                <span class="text-muted small ms-1">Sale</span>
            }
            @if (listing.RentalPricePerDay.HasValue && listing.RentalPricePerDay > 0)
            {
                <span class="fw-bold text-primary ms-2">$@listing.RentalPricePerDay.Value.ToString("N0")</span>
                <span class="text-muted small ms-1">/day</span>
            }
        </div>
        <div class="text-muted small mb-3">
            <i class="fas fa-user me-1"></i>@listing.SellerName
            &nbsp;<i class="fas fa-calendar ms-2 me-1"></i>@listing.CreatedDate.ToString("dd MMM yyyy")
        </div>

        <div class="d-flex gap-2 flex-wrap">
            @* Buy / Request button *@
            @if (!isMine && canTransact)
            {
                if (approved)
                {
                    <span class="badge bg-success p-2"><i class="fas fa-check me-1"></i>Purchased</span>
                }
                else if (pending)
                {
                    <span class="badge bg-warning text-dark p-2"><i class="fas fa-clock me-1"></i>Request Sent</span>
                }
                else
                {
                    <form asp-action="RequestToBuy" asp-route-id="@listing.Id" method="post" style="display:inline;">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-success">
                            <i class="fas fa-shopping-cart me-1"></i>Request to Buy
                        </button>
                    </form>
                }
            }
            else if (!isMine && !canTransact && User.Identity!.IsAuthenticated)
            {
                <span class="badge bg-secondary p-2">View Only</span>
            }

            @* Seller actions: only the original seller can edit/delete *@
            @if (isMine)
            {
                <span class="badge bg-info text-dark p-2 me-1"><i class="fas fa-store me-1"></i>Your Listing</span>
                <a href="@Url.Action("Edit","Marketplace", new{id=listing.Id})" class="btn btn-sm btn-outline-primary">
                    <i class="fas fa-edit"></i> Edit
                </a>
                <form asp-action="Delete" asp-route-id="@listing.Id" method="post" style="display:inline;"
                      onsubmit="return confirm('Remove this listing?');">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-sm btn-danger">
                        <i class="fas fa-trash"></i> Delete
                    </button>
                </form>
            }
        </div>
    </div>
</div>
}
</div>