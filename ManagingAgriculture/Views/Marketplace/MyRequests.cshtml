@model IEnumerable<ManagingAgriculture.Models.MarketplacePurchaseRequest>
@{
    ViewData["Title"] = "My Purchase Requests";
}

<div class="dashboard-container">
    <div class="page-header">
        <div>
            <h2><i class="fas fa-inbox me-2"></i>Incoming Purchase Requests</h2>
            <p class="subtitle">Review and approve requests for your marketplace listings</p>
        </div>
        <a asp-action="Index" class="btn btn-secondary">
            <i class="fas fa-arrow-left me-1"></i>Back to Marketplace
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mt-3">
            <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mt-3">
            <i class="fas fa-exclamation-triangle me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-body p-0">
            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Listing</th>
                                <th>Buyer</th>
                                <th>Requested On</th>
                                <th>Listed Price</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var req in Model)
                            {
                                <tr>
                                    <td>
                                        <strong>@req.Listing?.ItemName</strong>
                                        <div class="small text-muted">@req.Listing?.Category · @req.Listing?.ConditionStatus</div>
                                    </td>
                                    <td>
                                        <span class="badge bg-info text-dark">@req.BuyerName</span>
                                        <div class="small text-muted">@req.BuyerUser?.Email</div>
                                    </td>
                                    <td class="text-muted small">@req.RequestedDate.ToString("dd MMM yyyy HH:mm")</td>
                                    <td class="fw-bold text-success">
                                        @if (req.Listing?.SalePrice.HasValue == true && req.Listing.SalePrice > 0)
                                        {
                                            <text>$@req.Listing.SalePrice.Value.ToString("N0")</text>
                                        }
                                        else
                                        {
                                            <span class="text-muted">N/A</span>
                                        }
                                    </td>
                                    <td>
                                        <div class="d-flex gap-2">
                                            <form asp-action="ApproveRequest" method="post" style="display:inline;">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="requestId" value="@req.Id" />
                                                <button type="submit" class="btn btn-sm btn-success"
                                                        onclick="return confirm('Approve this request? The machinery will be transferred to the buyer.');">
                                                    <i class="fas fa-check me-1"></i>Approve
                                                </button>
                                            </form>
                                            <form asp-action="RejectRequest" method="post" style="display:inline;">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="requestId" value="@req.Id" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger"
                                                        onclick="return confirm('Reject this request?');">
                                                    <i class="fas fa-times me-1"></i>Reject
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5 text-muted">
                    <i class="fas fa-inbox fa-3x mb-3 opacity-25"></i>
                    <p class="fs-5">No pending purchase requests for your listings.</p>
                </div>
            }
        </div>
    </div>
</div>
