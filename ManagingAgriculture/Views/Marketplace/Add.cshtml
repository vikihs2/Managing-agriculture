@model ManagingAgriculture.Models.MarketplaceListing
@{
    ViewData["Title"] = "Post Listing";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="card mx-auto" style="max-width:720px;">
        <div class="card-body">
            <h3 class="card-title mb-3"><i class="fas fa-plus-circle me-2"></i>Post New Marketplace Listing</h3>
            <form asp-action="Add" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                @if (ViewBag.UserMachinery != null && ((List<ManagingAgriculture.Models.Machinery>)ViewBag.UserMachinery).Any())
                {
                    <div class="mb-3">
                        <label class="form-label fw-bold">Choose from your existing machinery</label>
                        <select name="selectedMachineryId" id="selectedMachineryId" class="form-select">
                            <option value="">-- Select machinery to auto-fill (optional) --</option>
                            @foreach (var m in (List<ManagingAgriculture.Models.Machinery>)ViewBag.UserMachinery)
                            {
                                <option value="@m.Id">@m.Name (@m.Type) - @m.Status</option>
                            }
                        </select>
                    </div>
                }

                <!-- Item Name -->
                <div class="mb-3">
                    <label asp-for="ItemName" class="form-label fw-bold">Item Name *</label>
                    <input asp-for="ItemName" class="form-control" placeholder="e.g., John Deere Tractor" />
                    <span asp-validation-for="ItemName" class="text-danger"></span>
                </div>

                <!-- Condition Status -->
                <div class="mb-3">
                    <label asp-for="ConditionStatus" class="form-label fw-bold">Condition *</label>
                    <select asp-for="ConditionStatus" class="form-control">
                        <option value="">-- Select Condition --</option>
                        <option value="New">New</option>
                        <option value="Excellent">Excellent</option>
                        <option value="Good">Good</option>
                        <option value="Fair">Fair</option>
                        <option value="Poor">Poor</option>
                    </select>
                    <span asp-validation-for="ConditionStatus" class="text-danger"></span>
                </div>

                <!-- Description -->
                <div class="mb-3">
                    <label asp-for="Description" class="form-label fw-bold">Description</label>
                    <textarea asp-for="Description" class="form-control" rows="3" placeholder="Describe the machinery..."></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <!-- Engine Hours -->
                <div class="mb-3">
                    <label asp-for="EngineHours" class="form-label fw-bold">Engine Hours (h)</label>
                    <input asp-for="EngineHours" class="form-control" type="number" step="0.1" min="0" placeholder="e.g., 123.4" required />
                    <span asp-validation-for="EngineHours" class="text-danger"></span>
                </div>

                <!-- Condition -->
                <div class="mb-3">
                    <label asp-for="ConditionStatus" class="form-label fw-bold">Condition</label>
                    <input asp-for="ConditionStatus" class="form-control" type="text" placeholder="e.g. Good" required />
                    <span asp-validation-for="ConditionStatus" class="text-danger"></span>
                </div>

                <!-- Listing Type and Pricing -->
                <hr class="my-4" />
                <h5 class="mb-3">Listing Type &amp; Pricing</h5>

                <div class="mb-3">
                    <label asp-for="ListingType" class="form-label fw-bold">I want to:</label>
                    <select asp-for="ListingType" class="form-control" id="listingType">
                        <option value="">-- Select Option --</option>
                        <option value="Sale">Sell only</option>
                        <option value="Rent">Rent only</option>
                        <option value="Both">Sell and/or Rent</option>
                    </select>
                    <span asp-validation-for="ListingType" class="text-danger"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="SalePrice" class="form-label fw-bold">Sale Price ($)</label>
                        <input asp-for="SalePrice" class="form-control" type="number" step="0.01" min="0" placeholder="0.00" />
                        <span asp-validation-for="SalePrice" class="text-danger"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="RentalPricePerDay" class="form-label fw-bold">Daily Rental Price ($)</label>
                        <input asp-for="RentalPricePerDay" class="form-control" type="number" step="0.01" min="0" placeholder="0.00" />
                        <span asp-validation-for="RentalPricePerDay" class="text-danger"></span>
                    </div>
                </div>

                <!-- Seller Info (auto-filled, contact phone editable) -->
                <hr class="my-4" />
                <h5 class="mb-3">Your Contact Information</h5>

                <div class="mb-3">
                    <label class="form-label fw-bold">Seller Name</label>
                    <input asp-for="SellerName" class="form-control" readonly style="background:#f8f9fa;" />
                    <small class="text-muted">Auto-filled from your account name</small>
                </div>

                <div class="mb-3">
                    <label asp-for="SellerPhone" class="form-label fw-bold">Contact Phone</label>
                    <input asp-for="SellerPhone" class="form-control" type="tel" placeholder="555-1234" />
                    <span asp-validation-for="SellerPhone" class="text-danger"></span>
                </div>

                <!-- Image URL (Optional) -->
                <div class="mb-3">
                    <label asp-for="ImageUrl" class="form-label fw-bold">Image URL <small class="text-muted fw-normal">(Optional)</small></label>
                    <input asp-for="ImageUrl" class="form-control" type="url" placeholder="https://example.com/image.jpg" />
                    <span asp-validation-for="ImageUrl" class="text-danger"></span>
                    <small class="text-muted">Provide a full URL to an image hosted online</small>
                </div>

                <!-- Form Actions -->
                <div class="d-flex justify-content-between mt-4">
                    <a href="@Url.Action("Index", "Marketplace")" class="btn btn-cancel">
                        <i class="fas fa-times"></i> Cancel
                    </a>
                    <button type="submit" class="btn btn-save">
                        <i class="fas fa-save"></i> Post Listing
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    (function(){
        var select = document.getElementById('selectedMachineryId');
        if (!select) return;
        select.addEventListener('change', function(){
            var id = this.value;
            if (!id) return;
            fetch('/Machinery/DetailsApi/' + id)
                .then(r => r.json())
                .then(data => {
                    if (data) {
                        var nameEl = document.querySelector('[name="ItemName"]');
                        var descEl = document.querySelector('[name="Description"]');
                        var conditionEl = document.querySelector('[name="ConditionStatus"]');
                        var hoursEl = document.querySelector('[name="EngineHours"]');
                        if (nameEl && !nameEl.value) nameEl.value = data.name;
                        if (descEl && !descEl.value) descEl.value = data.type + ' - ' + data.name;
                        if (conditionEl && !conditionEl.value) conditionEl.value = data.status;
                        if (hoursEl && (!hoursEl.value || hoursEl.value == 0)) hoursEl.value = data.engineHours || 0;
                    }
                })
                .catch(()=>{});
        });
    })();
</script>
