@model List<ManagingAgriculture.Models.Field>
@{
    ViewData["Title"] = "Fields";
    bool canManage = ViewBag.CanManage == true;
}

<div class="dashboard-container">

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="fas fa-exclamation-triangle me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Page Header Card -->
    <div class="card mb-4 border-0 shadow-sm" style="background: linear-gradient(135deg, #2d6a4f 0%, #40916c 100%); color: white;">
        <div class="card-body py-4">
            <div class="d-flex align-items-center gap-3">
                <div style="font-size: 3rem;">🌾</div>
                <div>
                    <!-- Title is handled by _Layout.cshtml -->
                    <p class="mb-0 opacity-75">Manage your agricultural fields and their properties</p>
                </div>
                @if (canManage)
                {
                    <div class="ms-auto">
                        <a asp-action="Create" class="btn btn-light fw-bold">
                            <i class="fas fa-plus me-1"></i> Add New Field
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>

    @if (Model != null && Model.Count > 0)
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @foreach (var field in Model)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm border-0">
                        <div class="card-header d-flex justify-content-between align-items-center"
                             style="background: linear-gradient(135deg, #1b4332, #2d6a4f); color: white;">
                            <h5 class="mb-0">
                                <i class="fas fa-map-marked-alt me-2"></i>@field.Name
                            </h5>
                            @if (field.IsOccupied)
                            {
                                <span class="badge bg-warning text-dark">🌱 Occupied</span>
                            }
                            else
                            {
                                <span class="badge bg-success">✅ Available</span>
                            }
                        </div>
                        <div class="card-body">
                            <table class="table table-sm table-borderless mb-0">
                                <tr>
                                    <td class="text-muted"><i class="fas fa-ruler-combined me-1"></i>Size</td>
                                    <td class="fw-bold">@field.SizeInDecars decars</td>
                                </tr>
                                <tr>
                                    <td class="text-muted"><i class="fas fa-map-pin me-1"></i>City</td>
                                    <td class="fw-bold">@field.City</td>
                                </tr>
                                <tr>
                                    <td class="text-muted"><i class="fas fa-layer-group me-1"></i>Soil</td>
                                    <td class="fw-bold">@field.SoilType</td>
                                </tr>
                                <tr>
                                    <td class="text-muted"><i class="fas fa-sun me-1"></i>Sunlight</td>
                                    <td class="fw-bold">@field.SunlightExposure</td>
                                </tr>
                                <tr>
                                    <td class="text-muted"><i class="fas fa-thermometer-half me-1"></i>Avg Temp</td>
                                    <td class="fw-bold">@field.AverageTemperatureCelsius°C</td>
                                </tr>
                            </table>
                        </div>
                        @if (canManage)
                        {
                            <div class="card-footer bg-light d-flex gap-2">
                                <a asp-action="Edit" asp-route-id="@field.Id" class="btn btn-sm btn-primary flex-grow-1">
                                    <i class="fas fa-edit me-1"></i>Edit
                                </a>
                                @if (!field.IsOccupied)
                                {
                                    <form asp-action="Delete" asp-route-id="@field.Id" method="post" style="flex-grow:1;">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-danger w-100"
                                                onclick="return confirm('Delete this field?');">
                                            <i class="fas fa-trash me-1"></i>Delete
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-secondary flex-grow-1" disabled title="Harvest the plant first">
                                        <i class="fas fa-lock me-1"></i>Occupied
                                    </button>
                                }
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <div style="font-size: 5rem; opacity: 0.3;">🌾</div>
            <h4 class="text-muted">No fields yet</h4>
            @if (canManage)
            {
                <p class="text-muted">Fields are needed for plant tracking. Add your first field to get started.</p>
                <a asp-action="Create" class="btn btn-success mt-2">
                    <i class="fas fa-plus me-1"></i>Create First Field
                </a>
            }
            else
            {
                <p class="text-muted">No fields have been created yet. Ask your team boss to add fields.</p>
            }
        </div>
    }
</div>
