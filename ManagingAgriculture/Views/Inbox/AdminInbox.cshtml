@model IEnumerable<ManagingAgriculture.Models.ContactForm>
@{
    ViewData["Title"] = "Support Inbox";
}

<div class="dashboard-container">
    <div class="page-header">
        <div>
            <!-- Title is handled by _Layout.cshtml -->
            <p class="subtitle">All messages from users — reply to resolve their inquiries</p>
        </div>
        <div class="d-flex gap-2">
            <span class="badge bg-danger fs-6">
                @Model.Count(m => !m.IsReplied) unreplied
            </span>
            <span class="badge bg-success fs-6">
                @Model.Count(m => m.IsReplied) resolved
            </span>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mt-2">
            <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-body p-0">
            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Date</th>
                                <th>From</th>
                                <th>Email</th>
                                <th>Message</th>
                                <th>Reply</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var msg in Model)
                            {
                                <tr class="@(msg.IsReplied ? "" : "table-warning")">
                                    <td class="text-muted small">@msg.CreatedDate.ToString("dd MMM yyyy HH:mm")</td>
                                    <td><strong>@msg.FullName</strong></td>
                                    <td class="small">@msg.Email</td>
                                    <td style="max-width:300px;">
                                        <div style="white-space:pre-wrap; word-break:break-word; font-size:0.87rem;">@msg.Message</div>
                                    </td>
                                    <td style="min-width:280px;">
                                        @if (msg.IsReplied)
                                        {
                                            <div class="alert alert-success p-2 mb-1 small">
                                                <i class="fas fa-check me-1"></i><strong>@msg.RepliedBy</strong> replied:
                                                <div>@msg.ReplyMessage</div>
                                                <div class="text-muted">@msg.RepliedDate?.ToString("dd MMM yyyy HH:mm")</div>
                                            </div>
                                        }
                                        else
                                        {
                                            <form asp-action="Reply" asp-controller="Inbox" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@msg.Id" />
                                                <div class="input-group input-group-sm">
                                                    <textarea name="replyContent" class="form-control" rows="2"
                                                              placeholder="Type your reply..." required></textarea>
                                                    <button type="submit" class="btn btn-success btn-sm">
                                                        <i class="fas fa-paper-plane"></i>
                                                    </button>
                                                </div>
                                            </form>
                                        }
                                    </td>
                                    <td>
                                        @if (msg.IsReplied)
                                        {
                                            <span class="badge bg-success">✅ Resolved</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning text-dark">⏳ Pending</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5 text-muted">
                    <i class="fas fa-inbox fa-3x mb-3 opacity-25"></i>
                    <p class="fs-5">No messages yet.</p>
                </div>
            }
        </div>
    </div>
</div>
