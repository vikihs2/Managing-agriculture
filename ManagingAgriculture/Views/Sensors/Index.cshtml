@{
    ViewData["Title"] = "Soil Humidity Monitor";
}

<div class="soil-container">
    <div class="page-header">
        <div>
            <!-- Title is handled by _Layout.cshtml -->
            <p class="subtitle">Real-time soil moisture and temperature tracking</p>
        </div>
    </div>

    <div class="soil-stats-grid">
        <div class="soil-stat-card">
            <div class="soil-stat-header">
                <span>Current Humidity</span>
                <i class="fas fa-tint"></i>
            </div>

            <!-- LIVE VALUE -->
            <div class="soil-stat-value" id="humidityValue">--%</div>

            <div class="soil-stat-sub">Live sensor data</div>
            <span class="soil-badge optimal">Live</span>
        </div>

        <div class="soil-stat-card">
            <div class="soil-stat-header">
                <span>Temperature</span>
                <select id="weatherCity" class="form-select form-select-sm" style="width: 130px; border: 1px solid #ddd; border-radius: 4px; font-size: 0.85rem; padding: 2px 5px;">
                     <option value="42.6977,23.3219">Sofia</option>
                     <option value="42.1438,24.7497">Plovdiv</option>
                     <option value="43.2046,27.9105">Varna</option>
                     <option value="42.5061,27.4678">Burgas</option>
                     <option value="43.8564,25.9708">Ruse</option>
                     <option value="42.4328,25.6419">Stara Zagora</option>
                     <option value="43.4170,24.6067">Pleven</option>
                     <option value="42.6858,26.3292">Sliven</option>
                     <option value="43.5667,27.8333">Dobrich</option>
                     <option value="43.2706,26.9229">Shumen</option>
                </select>
                <i class="fas fa-thermometer-half"></i>
            </div>
            <div class="soil-stat-value" id="weather-temp">--°C</div>
            <div class="soil-stat-sub" id="weather-condition">Fetching weather...</div>
            <span class="soil-badge normal">Outdoor</span>
        </div>

        <div class="soil-stat-card">
            <div class="soil-stat-header">
                <span>Sensor Status</span>
                <i class="fas fa-wave-square"></i>
            </div>
            <div class="soil-stat-value status-online">
                <i class="fas fa-circle"></i> Online
            </div>
            <div class="soil-stat-sub">
                Field A - Sensor 1<br />
                Last update: <span id="lastUpdate">--</span>
            </div>
        </div>
    </div>

    <div class="soil-readings-section">
        <h3>24-Hour Readings</h3>
        <p class="section-subtitle">Soil humidity and temperature trends</p>
        <div class="soil-chart-wrapper">
            <canvas id="soilChart" height="120"></canvas>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

        <script>
        // LIVE SENSOR FETCH
        function updateSensor() {
            fetch('/Sensors/GetWaterLevel')
                .then(r => r.json())
                .then(d => {
                    const percent = Math.min(100, Math.round((d.value / 1023) * 100));
                    document.getElementById('humidityValue').innerText = percent + '%';
                    document.getElementById('lastUpdate').innerText = new Date().toLocaleTimeString();
                })
                .catch(() => {
                    document.getElementById('humidityValue').innerText = '--%';
                });
        }

        setInterval(updateSensor, 300);
    </script>

    <script>
        const ctx = document.getElementById('soilChart').getContext('2d');
        let activeIndex = null;

        const timeLabels = [
            '12:27 PM', '01:27 PM', '02:27 PM', '03:27 PM', '04:27 PM', '05:27 PM',
            '06:27 PM', '07:27 PM', '08:27 PM', '09:27 PM', '10:27 PM', '11:27 PM',
            '12:27 AM', '01:27 AM', '02:27 AM', '03:27 AM', '04:27 AM', '05:27 AM',
            '06:27 AM', '07:27 AM', '08:27 AM', '09:27 AM', '10:27 AM', '11:27 AM'
        ];

        const humidityData = [63.4, 61.0, 58.2, 60.0, 61.7, 58.6, 55.5, 57.8, 60.1, 59.0, 57.8, 56.0,
            54.2, 55.5, 56.7, 58.0, 59.3, 56.5, 53.8, 55.5, 57.1, 58.6, 60.2, 61.0];

        const temperatureData = [21.4, 21.8, 22.1, 22.6, 23.2, 23.8, 24.5, 24.8, 25.1, 25.0, 24.8, 24.2,
            23.6, 23.8, 22.9, 23.0, 23.2, 23.7, 24.1, 24.5, 25.0, 25.1, 25.1, 25.0];

        const soilChart = new Chart(ctx, {
            type: 'line',
            data: {
                labels: timeLabels,
                datasets: [
                    {
                        label: 'Humidity (%)',
                        data: humidityData,
                        borderColor: '#2196f3',
                        backgroundColor: 'rgba(33,150,243,0.08)',
                        pointRadius: 0,
                        tension: 0.3
                    },
                    {
                        label: 'Temperature (°C)',
                        data: temperatureData,
                        borderColor: '#ff9800',
                        backgroundColor: 'rgba(255,152,0,0.08)',
                        pointRadius: 0,
                        tension: 0.3
                    }
                ]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: { position: 'bottom' }
                },
                interaction: {
                    mode: 'index',
                    intersect: false
                }
            }
        });
    </script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const citySelect = document.getElementById('weatherCity');
            
            function loadWeather() {
                const [lat, lng] = citySelect.value.split(',');
                
                fetch(`https://api.open-meteo.com/v1/forecast?latitude=${lat}&longitude=${lng}&current_weather=true`)
                .then(response => response.json())
                .then(data => {
                    if(data.current_weather) {
                        const w = data.current_weather;
                        document.getElementById('weather-temp').innerText = w.temperature + "°C";
                        
                        let condition = 'Clear';
                        if(w.weathercode > 3) condition = 'Cloudy';
                        if(w.weathercode > 50) condition = 'Rainy';
                        if(w.weathercode > 70) condition = 'Snowy';

                        document.getElementById('weather-condition').innerText = condition + " in " + citySelect.options[citySelect.selectedIndex].text;
                    }
                })
                .catch(err => {
                    document.getElementById('weather-temp').innerText = "Error";
                    document.getElementById('weather-condition').innerText = "Failed to load";
                });
            }

            const savedCity = localStorage.getItem('weatherCitySetting');
            if (savedCity) {
                citySelect.value = savedCity;
            }

            citySelect.addEventListener('change', function() {
                localStorage.setItem('weatherCitySetting', this.value);
                loadWeather();
            });

            loadWeather();
            // Refresh weather every 10 minutes
            setInterval(loadWeather, 600000);
        });
    </script>
}
