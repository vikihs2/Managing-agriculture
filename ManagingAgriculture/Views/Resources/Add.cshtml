@model ManagingAgriculture.Models.Resource
@{
    ViewData["Title"] = "Add Resource";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="card mx-auto" style="max-width:720px;">
        <div class="card-body">
            <h3 class="card-title mb-3">Add Resource</h3>
            <form asp-action="Add" method="post">
                @Html.AntiForgeryToken()
                <div class="mb-3">
                    <label asp-for="Name" class="form-label">Name</label>
                    <input asp-for="Name" class="form-control" />
                </div>
                <div class="mb-3">
                    <label asp-for="Category" class="form-label">Category</label>
                    <select asp-for="Category" class="form-select">
                        <option value="Fertilizer">Fertilizer</option>
                        <option value="Seed">Seed</option>
                        <option value="Chemical">Chemical</option>
                        <option value="Water">Water</option>
                        <option value="Fuel">Fuel</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label asp-for="Quantity" class="form-label">Quantity</label>
                    <input asp-for="Quantity" class="form-control" />
                </div>
                <div class="mb-3">
                    <label asp-for="Unit" class="form-label">Unit of Measure</label>
                    <select asp-for="Unit" class="form-select">
                        <option value="kg">kg</option>
                        <option value="g">g</option>
                        <option value="tons">tons</option>
                        <option value="liters">liters</option>
                        <option value="ml">ml</option>
                        <option value="m³">m³</option>
                        <option value="pieces">pieces</option>
                        <option value="units">units</option>
                        <option value="bags">bags</option>
                        <option value="boxes">boxes</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label asp-for="LowStockThreshold" class="form-label">Low Stock Threshold</label>
                    <input asp-for="LowStockThreshold" class="form-control" />
                </div>
                <div class="mb-3">
                    <label asp-for="Supplier" class="form-label">Supplier</label>
                    <input asp-for="Supplier" class="form-control" />
                </div>
                <div class="d-flex justify-content-between mt-4">
                    <a href="@Url.Action("Index","Resources")" class="btn btn-cancel"><i class="fas fa-times"></i> Cancel</a>
                    <button type="submit" class="btn btn-save"><i class="fas fa-save"></i> Add Resource</button>
                </div>
            </form>
        </div>
    </div>
</div>
